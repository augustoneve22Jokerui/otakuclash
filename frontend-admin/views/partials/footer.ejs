<!-- Module Specific JS (Loaded dynamically via router controller) -->
<% if (typeof moduleScript !== 'undefined') { %>
    <script src="/assets/js/modules/<%= moduleScript %>.js"></script>
<% } %>

<!-- Final Layout Initialization -->
<script>
    // Ativa animações AOS
    AOS.init({
        duration: 800,
        easing: 'ease-in-out',
        once: true
    });

    // Listener para o atalho Global Search (Ctrl + K)
    document.addEventListener('keydown', function(e) {
        if (e.ctrlKey && e.key === 'k') {
            e.preventDefault();
            document.getElementById('global-search-input').focus();
        }
    });

    // Sincronização automática da presença do usuário (Keep-alive)
    if (window.Socket && window.Auth.isAuthenticated()) {
        window.addEventListener('beforeunload', () => {
            // Informa ao servidor que o usuário está fechando a aba/janela
            // O Socket.io nativo trata o disconnect, mas aqui podemos disparar eventos específicos se necessário
        });
    }
</script>