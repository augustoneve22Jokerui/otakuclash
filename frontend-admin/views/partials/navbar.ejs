<!-- 
 * OTAKU CLASH ANGOLA - GLOBAL NAVIGATION BAR
 * Senior UI Designer: Top Bar Architecture & Interactive Controls
-->
<nav class="navbar navbar-custom glass-effect fixed-top">
    <div class="container-fluid px-3 px-lg-4">
        <!-- Left Side: Sidebar Toggle & Quick Links -->
        <div class="d-flex align-items-center">
            <button class="btn-sidebar-toggle me-3" id="sidebarToggle" title="Recolher/Expandir Menu">
                <i class="bi bi-list fs-4"></i>
            </button>
            
            <!-- Global Search Bar (Real-time Filter) -->
            <div class="navbar-search-wrapper d-none d-md-flex">
                <i class="bi bi-search search-icon"></i>
                <input type="text" class="form-control border-0 bg-transparent ps-5" 
                       placeholder="Buscar usuários, animes, partidas..." 
                       id="global-search-input">
                <span class="search-shortcut">Ctrl + K</span>
            </div>
        </div>

        <!-- Right Side: Utils & Identity -->
        <div class="navbar-actions d-flex align-items-center">
            
            <!-- Theme Toggle -->
            <button class="btn-action-nav theme-toggle-btn me-2" title="Alternar Modo Escuro/Claro">
                <i class="bi bi-moon-stars theme-toggle-icon"></i>
            </button>

            <!-- Language Selector (Angola Focus) -->
            <div class="dropdown me-2">
                <button class="btn-action-nav" data-bs-toggle="dropdown" aria-expanded="false">
                    <img src="https://flagcdn.com/w20/ao.png" width="20" alt="AO" class="rounded-1">
                </button>
                <ul class="dropdown-menu dropdown-menu-end shadow-lg border-secondary">
                    <li><a class="dropdown-item d-flex align-items-center gap-2" href="#"><img src="https://flagcdn.com/w20/ao.png" width="16" alt="AO"> Português (AO)</a></li>
                    <li><a class="dropdown-item d-flex align-items-center gap-2" href="#"><img src="https://flagcdn.com/w20/br.png" width="16" alt="BR"> Português (BR)</a></li>
                    <li><a class="dropdown-item d-flex align-items-center gap-2" href="#"><img src="https://flagcdn.com/w20/us.png" width="16" alt="US"> English (US)</a></li>
                </ul>
            </div>

            <!-- Notifications Dropdown -->
            <div class="dropdown me-3">
                <button class="btn-action-nav position-relative" id="notifyDropdown" data-bs-toggle="dropdown" data-bs-auto-close="outside" aria-expanded="false">
                    <i class="bi bi-bell-fill"></i>
                    <!-- Notification Badge (Updated by Socket.IO) -->
                    <span class="notification-badge" id="navbar-notification-count" style="display: none;">0</span>
                </button>
                
                <div class="dropdown-menu dropdown-menu-end navbar-notify-dropdown shadow-lg animate-up p-0" aria-labelledby="notifyDropdown">
                    <div class="notify-dropdown-header">
                        <span class="fw-bold">Central de Alertas</span>
                        <a href="/notifications" class="text-primary small text-decoration-none">Ver todos</a>
                    </div>
                    <div class="notify-dropdown-body" id="navbar-notification-list">
                        <!-- Items injected by JS from Real API -->
                        <div class="text-center py-4 text-muted small">
                            <i class="bi bi-mailbox me-2"></i>Nenhuma notificação nova
                        </div>
                    </div>
                    <div class="notify-dropdown-footer">
                        <button class="btn btn-sm text-dim w-100" onclick="Notifications.handleMarkAllRead()">
                            Limpar todas as pendências
                        </button>
                    </div>
                </div>
            </div>

            <!-- User Profile Dropdown -->
            <div class="dropdown user-dropdown">
                <button class="d-flex align-items-center border-0 bg-transparent p-0" data-bs-toggle="dropdown" aria-expanded="false">
                    <div class="user-meta-nav text-end me-2 d-none d-lg-block">
                        <div class="username-nav fw-bold text-main line-clamp-1" id="nav-display-name">Admin OC</div>
                        <div class="role-nav text-dim small" id="nav-display-role">Super Administrador</div>
                    </div>
                    <div class="user-avatar-wrapper position-relative">
                        <img src="/assets/img/placeholders/avatar.png" alt="Avatar" class="avatar-nav" id="nav-display-avatar">
                        <span class="status-pulse-green position-absolute bottom-0 end-0"></span>
                    </div>
                </button>
                <ul class="dropdown-menu dropdown-menu-end shadow-lg border-secondary mt-2 animate-up">
                    <li class="px-3 py-2 border-bottom border-secondary mb-2 d-lg-none">
                        <div class="fw-bold text-main" id="nav-mobile-name">Admin OC</div>
                        <small class="text-muted" id="nav-mobile-role">Super Administrador</small>
                    </li>
                    <li><a class="dropdown-item py-2" href="/profiles/me"><i class="bi bi-person-circle me-2"></i> Meu Perfil</a></li>
                    <li><a class="dropdown-item py-2" href="/settings"><i class="bi bi-shield-lock me-2"></i> Segurança</a></li>
                    <li><a class="dropdown-item py-2" href="/settings"><i class="bi bi-gear me-2"></i> Configurações</a></li>
                    <li><hr class="dropdown-divider border-secondary"></li>
                    <li>
                        <a class="dropdown-item py-2 text-danger" href="javascript:void(0)" onclick="Auth.logout()">
                            <i class="bi bi-box-arrow-right me-2"></i> Sair do Painel
                        </a>
                    </li>
                </ul>
            </div>
        </div>
    </div>
</nav>

<!-- Logic to inject user data from localStorage immediately -->
<script>
    (function() {
        const user = JSON.parse(localStorage.getItem('oc_admin_user_info'));
        if (user) {
            document.getElementById('nav-display-name').innerText = user.username;
            document.getElementById('nav-display-role').innerText = user.role;
            if (user.profile && user.profile.avatarUrl) {
                document.getElementById('nav-display-avatar').src = user.profile.avatarUrl;
            }
            const mobileName = document.getElementById('nav-mobile-name');
            if (mobileName) mobileName.innerText = user.username;
            const mobileRole = document.getElementById('nav-mobile-role');
            if (mobileRole) mobileRole.innerText = user.role;
        }
    })();
</script>