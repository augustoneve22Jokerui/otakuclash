<!-- 
 * OTAKU CLASH ANGOLA - DYNAMIC BREADCRUMBS
 * Senior UI Designer: Navigation Hierarchy & Contextual UI
-->
<nav aria-label="breadcrumb" class="oc-breadcrumb-wrapper mb-4 animate-up">
    <ol class="breadcrumb mb-0 align-items-center">
        <!-- Home / Dashboard Root -->
        <li class="breadcrumb-item">
            <a href="/dashboard" class="text-dim text-decoration-none hover-primary d-flex align-items-center">
                <i class="bi bi-house-door-fill me-2"></i>
                <span>Início</span>
            </a>
        </li>

        <% if (typeof breadcrumbs !== 'undefined' && breadcrumbs.length > 0) { %>
            <!-- Loop through dynamic breadcrumb path -->
            <% breadcrumbs.forEach((crumb, index) => { %>
                <% if (index === breadcrumbs.length - 1) { %>
                    <!-- Current Page (Active) -->
                    <li class="breadcrumb-item active d-flex align-items-center" aria-current="page">
                        <i class="bi bi-chevron-right mx-2 text-dim separator-icon"></i>
                        <span class="text-main fw-bold"><%= crumb.name %></span>
                    </li>
                <% } else { %>
                    <!-- Intermediate Step -->
                    <li class="breadcrumb-item d-flex align-items-center">
                        <i class="bi bi-chevron-right mx-2 text-dim separator-icon"></i>
                        <a href="<%= crumb.url %>" class="text-dim text-decoration-none hover-primary"><%= crumb.name %></a>
                    </li>
                <% } %>
            <% }); %>
        <% } else { %>
            <!-- Default fallback using page title if no array is provided -->
            <li class="breadcrumb-item active d-flex align-items-center" aria-current="page">
                <i class="bi bi-chevron-right mx-2 text-dim separator-icon"></i>
                <span class="text-main fw-bold"><%= title %></span>
            </li>
        <% } %>
    </ol>
</nav>

<style>
    .oc-breadcrumb-wrapper {
        background: transparent;
        padding: 0;
    }

    .breadcrumb-item {
        font-size: 0.85rem;
        display: flex;
        align-items: center;
    }

    .breadcrumb-item + .breadcrumb-item::before {
        display: none; /* Hide default Bootstrap slash */
    }

    .separator-icon {
        font-size: 0.65rem;
        opacity: 0.5;
    }

    .breadcrumb-item a {
        transition: all var(--transition-speed);
    }

    .breadcrumb-item a:hover {
        color: var(--primary-color) !important;
    }

    .breadcrumb-item.active {
        letter-spacing: 0.3px;
    }
    
    /* Animation adjustment for breadcrumbs */
    .breadcrumb-item i.bi-house-door-fill {
        font-size: 1rem;
    }
</style>