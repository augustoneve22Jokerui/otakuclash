<!-- 
 * OTAKU CLASH ANGOLA - GLOBAL ALERTS & TOASTS SYSTEM
 * Senior UI Designer: Real-time Feedback & System Status UI
-->

<!-- 1. Toast Stack Container (Managed by window.showAlert in app.js) -->
<div id="oc-toast-container" class="toast-container position-fixed top-0 end-0 p-3" style="z-index: 10000;">
    <!-- Standard Bootstrap Toast Template (Clonado via JS se necessário, embora usemos SweetAlert2 para a maioria) -->
    <div id="liveToast" class="toast oc-toast hide" role="alert" aria-live="assertive" aria-atomic="true">
        <div class="toast-header bg-dark border-bottom border-secondary text-white">
            <i class="bi bi-info-circle text-primary me-2"></i>
            <strong class="me-auto" id="toast-title">Notificação</strong>
            <small class="text-dim" id="toast-time">agora</small>
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="toast" aria-label="Close"></button>
        </div>
        <div class="toast-body bg-card text-muted" id="toast-body">
            <!-- Conteúdo injetado -->
        </div>
    </div>
</div>

<!-- 2. Connectivity Status Banner (Integrated with socket.js) -->
<div id="connectivity-alert" class="connectivity-banner animate-up">
    <div class="container-fluid d-flex align-items-center justify-content-center gap-3">
        <div class="spinner-grow spinner-grow-sm text-white" role="status"></div>
        <span class="fw-bold">Tentando reconectar ao servidor em tempo real...</span>
    </div>
</div>

<!-- 3. Maintenance / Global System Alert (Static) -->
<% if (typeof globalAlert !== 'undefined' && globalAlert) { %>
    <div class="alert global-maintenance-alert alert-dismissible fade show animate-down" role="alert">
        <div class="d-flex align-items-center">
            <i class="bi bi-exclamation-triangle-fill fs-4 me-3"></i>
            <div>
                <strong class="text-white d-block"><%= globalAlert.title %></strong>
                <span class="small text-white-50"><%= globalAlert.message %></span>
            </div>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
<% } %>

<style>
    /* Connectivity Banner Positioning */
    .connectivity-banner {
        position: fixed;
        top: var(--navbar-height);
        left: 0;
        width: 100%;
        background-color: var(--primary-color);
        color: white;
        z-index: 1040;
        padding: 8px 0;
        font-size: 0.85rem;
        box-shadow: 0 4px 15px rgba(255, 59, 92, 0.3);
        display: none; /* Inicia oculto, controlado pelo Socket.io */
    }

    /* Global Alert Styling */
    .global-maintenance-alert {
        background: linear-gradient(90deg, var(--secondary-color), var(--primary-color));
        border: none;
        border-radius: 0;
        margin-bottom: 0;
        color: white;
        padding: 1rem 2rem;
    }

    /* Logic for Socket Integration */
    .socket-disconnected #connectivity-alert {
        display: block !important;
    }

    /* Custom Scrollbar for Toasts */
    .toast-body {
        max-height: 200px;
        overflow-y: auto;
    }
</style>

<script>
    /**
     * Handlers Globais de Conectividade
     * Escutam eventos disparados pelo socket.js
     */
    document.addEventListener('socket_disconnected', () => {
        document.body.classList.add('socket-disconnected');
    });

    document.addEventListener('socket_connected', () => {
        document.body.classList.remove('socket-disconnected');
        
        // Se houver banner visível, mostra feedback de sucesso
        const banner = document.getElementById('connectivity-alert');
        if (banner && getComputedStyle(banner).display !== 'none') {
            const bannerText = banner.querySelector('span');
            banner.style.backgroundColor = 'var(--success)';
            bannerText.innerText = 'Conexão restabelecida!';
            
            setTimeout(() => {
                banner.style.display = 'none';
                banner.style.backgroundColor = 'var(--primary-color)';
            }, 3000);
        }
    });
</script>