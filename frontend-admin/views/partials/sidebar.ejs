<!-- 
 * OTAKU CLASH ANGOLA - SIDEBAR NAVIGATION
 * Senior UI Designer: Navigation UX & Menu Architecture
-->
<aside id="sidebar" class="sidebar sidebar-transition">
    <!-- Sidebar Header: Branding -->
    <div class="sidebar-header">
        <a href="/dashboard" class="sidebar-brand">
            <img src="/assets/img/logo-full.png" alt="Otaku Clash Logo" class="brand-logo-full">
            <img src="/assets/img/logo-icon.png" alt="OC" class="brand-logo-icon">
        </a>
    </div>

    <!-- Sidebar Body: Menu Items -->
    <div class="sidebar-content">
        <div class="sidebar-section-label">Menu Principal</div>
        <ul class="nav flex-column">
            <!-- Dashboard -->
            <li class="nav-item">
                <a href="/dashboard" class="nav-link <%= active === 'dashboard' ? 'active' : '' %>">
                    <i class="bi bi-grid-1x2-fill"></i>
                    <span>Dashboard</span>
                </a>
            </li>

            <!-- Gestão de Usuários -->
            <li class="nav-item">
                <a href="#menu-users" class="nav-link collapsed" data-bs-toggle="collapse" role="button" aria-expanded="false">
                    <i class="bi bi-people-fill"></i>
                    <span>Usuários</span>
                    <i class="bi bi-chevron-down ms-auto arrow-icon"></i>
                </a>
                <div class="collapse <%= ['users', 'profiles'].includes(active) ? 'show' : '' %>" id="menu-users">
                    <ul class="nav flex-column ms-3">
                        <li class="nav-item">
                            <a href="/users" class="nav-link sub-link <%= active === 'users' ? 'active' : '' %>">Diretório Geral</a>
                        </li>
                        <li class="nav-item">
                            <a href="/profiles" class="nav-link sub-link <%= active === 'profiles' ? 'active' : '' %>">Perfis Sociais</a>
                        </li>
                    </ul>
                </div>
            </li>

            <div class="sidebar-section-label">Catálogo & Conteúdo</div>
            
            <!-- Animes -->
            <li class="nav-item">
                <a href="/animes" class="nav-link <%= active === 'animes' ? 'active' : '' %>">
                    <i class="bi bi-collection-play-fill"></i>
                    <span>Animes</span>
                </a>
            </li>

            <!-- Personagens -->
            <li class="nav-item">
                <a href="/characters" class="nav-link <%= active === 'characters' ? 'active' : '' %>">
                    <i class="bi bi-person-bounding-box"></i>
                    <span>Personagens</span>
                </a>
            </li>

            <!-- Banco de Questões -->
            <li class="nav-item">
                <a href="/questions" class="nav-link <%= active === 'questions' ? 'active' : '' %>">
                    <i class="bi bi-patch-question-fill"></i>
                    <span>Questões</span>
                </a>
            </li>

            <div class="sidebar-section-label">Arena & Competição</div>

            <!-- Quiz Solo -->
            <li class="nav-item">
                <a href="/quiz" class="nav-link <%= active === 'quiz' ? 'active' : '' %>">
                    <i class="bi bi-controller"></i>
                    <span>Modos de Quiz</span>
                </a>
            </li>

            <!-- Partidas Real-time -->
            <li class="nav-item">
                <a href="/matches" class="nav-link <%= active === 'matches' ? 'active' : '' %>">
                    <i class="bi bi-lightning-charge-fill"></i>
                    <span>Duelos 1v1</span>
                    <span class="badge bg-primary ms-auto" id="live-matches-count">0</span>
                </a>
            </li>

            <!-- Battle Royale -->
            <li class="nav-item">
                <a href="/battle-royale" class="nav-link <%= active === 'battleroyale' ? 'active' : '' %>">
                    <i class="bi bi-sword"></i>
                    <span>Battle Royale</span>
                </a>
            </li>

            <!-- Torneios -->
            <li class="nav-item">
                <a href="/tournaments" class="nav-link <%= active === 'tournaments' ? 'active' : '' %>">
                    <i class="bi bi-trophy-fill"></i>
                    <span>Torneios Oficiais</span>
                </a>
            </li>

            <div class="sidebar-section-label">Economia & Rankings</div>

            <!-- Financeiro -->
            <li class="nav-item">
                <a href="#menu-finance" class="nav-link collapsed" data-bs-toggle="collapse" role="button" aria-expanded="false">
                    <i class="bi bi-wallet2"></i>
                    <span>Financeiro</span>
                    <i class="bi bi-chevron-down ms-auto arrow-icon"></i>
                </a>
                <div class="collapse <%= ['wallets', 'transactions', 'payments'].includes(active) ? 'show' : '' %>" id="menu-finance">
                    <ul class="nav flex-column ms-3">
                        <li class="nav-item">
                            <a href="/wallets" class="nav-link sub-link <%= active === 'wallets' ? 'active' : '' %>">Carteiras</a>
                        </li>
                        <li class="nav-item">
                            <a href="/transactions" class="nav-link sub-link <%= active === 'transactions' ? 'active' : '' %>">Ledger de Transações</a>
                        </li>
                        <li class="nav-item">
                            <a href="/payments" class="nav-link sub-link <%= active === 'payments' ? 'active' : '' %>">Gateways / MCX</a>
                        </li>
                    </ul>
                </div>
            </li>

            <!-- Rankings -->
            <li class="nav-item">
                <a href="/rankings" class="nav-link <%= active === 'rankings' ? 'active' : '' %>">
                    <i class="bi bi-bar-chart-line-fill"></i>
                    <span>Tiers e Ligas</span>
                </a>
            </li>

            <div class="sidebar-section-label">Social & Engajamento</div>

            <!-- Notificações -->
            <li class="nav-item">
                <a href="/notifications" class="nav-link <%= active === 'notifications' ? 'active' : '' %>">
                    <i class="bi bi-megaphone-fill"></i>
                    <span>Broadcast / Alertas</span>
                </a>
            </li>

            <!-- Conquistas -->
            <li class="nav-item">
                <a href="/achievements" class="nav-link <%= active === 'achievements' ? 'active' : '' %>">
                    <i class="bi bi-award-fill"></i>
                    <span>Conquistas</span>
                </a>
            </li>

            <!-- Guildas -->
            <li class="nav-item">
                <a href="/guilds" class="nav-link <%= active === 'guilds' ? 'active' : '' %>">
                    <i class="bi bi-shield-shaded"></i>
                    <span>Clãs e Guildas</span>
                </a>
            </li>

            <div class="sidebar-section-label">Sistema & Segurança</div>

            <!-- Moderação / Reports -->
            <li class="nav-item">
                <a href="/reports" class="nav-link <%= active === 'reports' ? 'active' : '' %>">
                    <i class="bi bi-exclamation-octagon-fill"></i>
                    <span>Denúncias</span>
                </a>
            </li>

            <!-- Audit Logs -->
            <li class="nav-item">
                <a href="/audit-logs" class="nav-link <%= active === 'audit-logs' ? 'active' : '' %>">
                    <i class="bi bi-shield-lock-fill"></i>
                    <span>Logs de Auditoria</span>
                </a>
            </li>

            <!-- Configurações -->
            <li class="nav-item">
                <a href="/settings" class="nav-link <%= active === 'settings' ? 'active' : '' %>">
                    <i class="bi bi-gear-fill"></i>
                    <span>Configurações Globais</span>
                </a>
            </li>

            <!-- Monitor de Saúde -->
            <li class="nav-item">
                <a href="/health-monitor" class="nav-link <%= active === 'health' ? 'active' : '' %>">
                    <i class="bi bi-activity"></i>
                    <span>Status da Infra</span>
                </a>
            </li>
        </ul>
    </div>

    <!-- Sidebar Footer: Profile Summary -->
    <div class="sidebar-footer">
        <div class="sidebar-user-card">
            <img src="/assets/img/placeholders/avatar.png" alt="Admin" class="user-avatar-sm" id="sidebar-avatar">
            <div class="user-info ms-2 overflow-hidden">
                <div class="username-text text-truncate" id="sidebar-username">Admin User</div>
                <div class="role-text" id="sidebar-role">Super Administrador</div>
            </div>
            <button class="btn-logout ms-auto" onclick="Auth.logout()" title="Encerrar Sessão">
                <i class="bi bi-box-arrow-right"></i>
            </button>
        </div>
    </div>
</aside>