<!DOCTYPE html>
<html lang="pt-AO" data-theme="dark">
<head>
    <%- include('../../partials/head-meta', { title: 'Gestão de Clãs e Guildas', moduleStyle: 'guilds' }) %>
</head>
<body>
    <div id="app-wrapper">
        <!-- Sidebar Navigation -->
        <%- include('../../partials/sidebar', { active: 'guilds' }) %>

        <div id="main-content" class="sidebar-transition">
            <!-- Top Navbar -->
            <%- include('../../partials/navbar') %>

            <main class="content-body">
                <!-- Breadcrumbs & Header -->
                <%- include('../../partials/breadcrumbs', { 
                    breadcrumbs: [
                        { name: 'Social & Engajamento', url: '#' },
                        { name: 'Clãs e Guildas', url: '/guilds' }
                    ] 
                }) %>

                <div class="section-header d-flex justify-content-between align-items-center mb-4">
                    <div>
                        <h2 class="text-main mb-1">Ecossistema de Guildas</h2>
                        <p class="text-muted small">Monitorize a progressão, membros e integridade dos clãs da plataforma.</p>
                    </div>
                    <div class="d-flex gap-2">
                        <button class="btn-oc btn-oc-outline" id="btn-refresh-guilds">
                            <i class="bi bi-arrow-clockwise me-2"></i> Actualizar Lista
                        </button>
                        <!-- A criação de guildas no admin é geralmente para fins de teste ou clãs oficiais -->
                        <button class="btn-oc btn-oc-primary" id="btn-create-official-guild" onclick="window.showAlert('Aviso', 'A criação de guildas oficiais via Admin será implementada na v2.2.', 'info')">
                            <i class="bi bi-shield-plus me-2"></i> Nova Guilda Oficial
                        </button>
                    </div>
                </div>

                <!-- Guild KPIs Row -->
                <div class="row g-4 mb-4" data-aos="fade-up">
                    <div class="col-md-3">
                        <div class="oc-card stat-card hover-lift">
                            <div class="stat-card-icon"><i class="bi bi-shield-shaded"></i></div>
                            <div class="stat-card-value" id="total-guilds-stat">0</div>
                            <div class="stat-card-label">Guildas Registadas</div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="oc-card stat-card hover-lift secondary">
                            <div class="stat-card-icon"><i class="bi bi-people-fill"></i></div>
                            <div class="stat-card-value" id="total-guild-members">0</div>
                            <div class="stat-card-label">Total de Membros</div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="oc-card stat-card hover-lift">
                            <div class="stat-card-icon text-warning"><i class="bi bi-lightning-charge-fill"></i></div>
                            <div class="stat-card-value" id="avg-guild-level">1.0</div>
                            <div class="stat-card-label">Média de Nível</div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="oc-card stat-card hover-lift primary">
                            <div class="stat-card-icon"><i class="bi bi-gem"></i></div>
                            <div class="stat-card-value" id="total-guild-xp">0</div>
                            <div class="stat-card-label">XP Global de Clãs</div>
                        </div>
                    </div>
                </div>

                <!-- Filters Bar -->
                <div class="oc-card mb-4" data-aos="fade-up">
                    <div class="row g-3 align-items-center">
                        <div class="col-lg-5 col-md-12">
                            <div class="auth-input-group mb-0">
                                <i class="bi bi-search"></i>
                                <input type="text" id="guild-search" class="form-control" placeholder="Buscar por nome ou TAG [TAG]...">
                            </div>
                        </div>
                        <div class="col-lg-4 col-md-6">
                            <div class="d-flex align-items-center gap-2">
                                <label class="oc-label mb-0 white-space-nowrap">Ordenar por:</label>
                                <select id="filter-guild-order" class="oc-input border-0 bg-dark">
                                    <option value="level">Nível (Maior)</option>
                                    <option value="xp">XP Acumulado</option>
                                    <option value="member_count">Número de Membros</option>
                                    <option value="created_at">Data de Fundação</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-lg-3 col-md-6">
                            <button class="btn-oc btn-oc-outline w-100" id="btn-export-guilds" onclick="Exporters.exportTableToCSV('guilds-table', 'diretorio_guildas_oc')">
                                <i class="bi bi-file-earmark-spreadsheet me-2"></i> Exportar Directório
                            </button>
                        </div>
                    </div>
                </div>

                <!-- Guilds Directory Table -->
                <div class="oc-card p-0 overflow-hidden" data-aos="fade-up">
                    <div id="guilds-loader" class="text-center py-5" style="display: none;">
                        <div class="spinner-custom mx-auto"></div>
                        <p class="text-muted mt-2 small">Sincronizando directório de clãs...</p>
                    </div>
                    <div class="oc-table-container">
                        <table class="oc-table mb-0" id="guilds-table">
                            <thead>
                                <tr>
                                    <th class="ps-4">Identidade da Guilda</th>
                                    <th>Progresso</th>
                                    <th>Membros</th>
                                    <th>Fundação</th>
                                    <th>Audit</th>
                                    <th class="text-end pe-4">Acções</th>
                                </tr>
                            </thead>
                            <tbody>
                                <!-- Injetado dinamicamente via guilds.js -->
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- Pagination Footer -->
                <div class="d-flex justify-content-between align-items-center mt-4" data-aos="fade-up">
                    <div class="text-dim small">
                        Mostrando directório de guildas activas
                    </div>
                    <div class="pagination-wrapper" id="guilds-pagination">
                        <!-- Gerado via JS -->
                    </div>
                </div>
            </main>

            <!-- Modal: Detalhes da Guilda (Admin View) -->
            <div class="modal fade" id="guild-detail-modal" tabindex="-1" aria-hidden="true">
                <div class="modal-dialog modal-dialog-centered modal-xl">
                    <div class="modal-content shadow-lg border-secondary bg-main">
                        <div class="modal-header border-secondary px-4 py-3">
                            <h5 class="modal-title fw-800 text-main">Análise de Clã</h5>
                            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                        </div>
                        <div class="modal-body p-0" id="guild-modal-body">
                            <!-- Populated dynamically via viewDetails method in guilds.js -->
                            <div class="text-center py-5">
                                <div class="spinner-border text-primary" role="status"></div>
                                <p class="text-muted mt-2">Recuperando dados do clã...</p>
                            </div>
                        </div>
                        <div class="modal-footer border-secondary bg-dark p-3">
                            <button type="button" class="btn-oc btn-oc-outline" data-bs-dismiss="modal">Fechar</button>
                            <button type="button" class="btn-oc btn-oc-primary" onclick="window.print()">
                                <i class="bi bi-printer me-2"></i> Relatório de Clã
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Global Footer & Scripts -->
            <%- include('../../partials/footer', { moduleScript: 'guilds/guilds' }) %>
        </div>
    </div>
</body>
</html>