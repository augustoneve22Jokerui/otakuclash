<!DOCTYPE html>
<html lang="pt-AO" data-theme="dark">
<head>
    <!-- Head Meta específico para Auth (Sem Sidebar/Navbar ainda) -->
    <%- include('../../partials/head-meta', { title: 'Login Administrativo', moduleStyle: 'auth' }) %>
    <link rel="stylesheet" href="/assets/css/global.css">
    <link rel="stylesheet" href="/styles/auth.css">
</head>
<body class="auth-page">
    <div class="auth-wrapper">
        <div class="container">
            <div class="row align-items-center min-vh-100">
                <!-- Column: Brand & Info (Visual Impact) -->
                <div class="col-lg-6 d-none d-lg-block animate-right">
                    <div class="auth-brand-content pe-lg-5">
                        <img src="/assets/img/logo-full.png" alt="Otaku Clash Logo" class="mb-4" style="height: 100px; filter: drop-shadow(0 0 15px rgba(255, 59, 92, 0.4));">
                        
                        <h1 class="display-4 fw-800 text-white mb-4">Painel Administrativo</h1>
                        <p class="text-muted fs-5 mb-5">Gerencie toda a plataforma Otaku Clash Angola de forma simples, rápida e segura.</p>

                        <div class="auth-features">
                            <div class="d-flex align-items-center mb-4 gap-3">
                                <div class="stat-card-icon primary"><i class="bi bi-shield-lock"></i></div>
                                <div>
                                    <h6 class="text-white mb-1 fw-bold">Seguro</h6>
                                    <p class="text-dim small mb-0">Protegido com autenticação avançada e criptografia de dados.</p>
                                </div>
                            </div>
                            <div class="d-flex align-items-center mb-4 gap-3">
                                <div class="stat-card-icon"><i class="bi bi-bar-chart"></i></div>
                                <div>
                                    <h6 class="text-white mb-1 fw-bold">Completo</h6>
                                    <p class="text-dim small mb-0">Todas as ferramentas que você precisa em um só lugar.</p>
                                </div>
                            </div>
                            <div class="d-flex align-items-center gap-3">
                                <div class="stat-card-icon text-warning"><i class="bi bi-lightning-charge"></i></div>
                                <div>
                                    <h6 class="text-white mb-1 fw-bold">Em Tempo Real</h6>
                                    <p class="text-dim small mb-0">Acompanhe tudo o que acontece na plataforma instantaneamente.</p>
                                </div>
                            </div>
                        </div>

                        <div class="mt-5 pt-4 border-top border-secondary border-opacity-25">
                            <p class="text-dim small">© 2026 Otaku Clash Angola. Todos os direitos reservados.</p>
                        </div>
                    </div>
                </div>

                <!-- Column: Login Card -->
                <div class="col-lg-5 offset-lg-1 col-md-8 offset-md-2 animate-up">
                    <div class="login-card shadow-lg">
                        <div class="auth-header mb-4 text-center text-lg-start">
                            <div class="access-restricted-badge">
                                <i class="bi bi-lock-fill me-2"></i> Acesso Restrito
                            </div>
                            <h2 class="fw-800 text-main mt-3">Bem-vindo de volta! 👋</h2>
                            <p class="text-muted small">Faça login para aceder ao painel administrativo.</p>
                        </div>

                        <form id="login-form">
                            <div class="oc-input-group auth-input-group">
                                <label class="oc-label" for="email">E-mail ou Nome de Usuário</label>
                                <i class="bi bi-envelope"></i>
                                <input type="email" id="email" name="email" class="form-control" 
                                       placeholder="Digite seu e-mail ou usuário" required data-validate="email">
                            </div>

                            <div class="oc-input-group auth-input-group">
                                <label class="oc-label" for="password">Senha</label>
                                <i class="bi bi-key"></i>
                                <input type="password" id="password" name="password" class="form-control" 
                                       placeholder="Digite sua senha" required>
                                <span class="password-toggle" id="toggle-password">
                                    <i class="bi bi-eye"></i>
                                </span>
                            </div>

                            <div class="auth-actions">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" id="remember-me">
                                    <label class="form-check-label text-muted small" for="remember-me">
                                        Lembrar-me
                                    </label>
                                </div>
                                <a href="javascript:void(0)" class="auth-link small fw-bold">Esqueceu sua senha?</a>
                            </div>

                            <button type="submit" class="btn-auth-submit mt-2" id="btn-login">
                                <span class="spinner-border spinner-border-sm d-none me-2" role="status"></span>
                                <span class="btn-text">Entrar no Painel</span>
                            </button>

                            <div class="auth-divider">
                                <span>ou continue com</span>
                            </div>

                            <button type="button" class="btn-oc btn-oc-outline w-100 py-2 fw-bold" onclick="showAlert('Aviso', 'A autenticação por 2FA via App será obrigatória em breve.', 'info')">
                                <i class="bi bi-shield-check me-2"></i> Autenticação com 2FA
                            </button>
                        </form>

                        <div class="auth-footer text-center mt-4">
                            <p class="text-muted small">Não tem acesso? Entre em contacto com o <a href="mailto:admin@otakuclash.ao" class="text-primary fw-bold">administrador</a>.</p>
                        </div>
                    </div>

                    <!-- Recommended Browser Notice -->
                    <div class="text-center mt-4 d-none d-md-block">
                        <div class="alert border-0 bg-dark bg-opacity-50 py-2 rounded-md">
                            <img src="https://www.google.com/chrome/static/images/chrome-logo.svg" width="16" class="me-2">
                            <span class="text-dim" style="font-size: 11px;">Recomendado: Use o Google Chrome para a melhor experiência.</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Core Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    
    <!-- Platform Auth Engine -->
    <script src="/assets/js/utils/validators.js"></script>
    <script src="/assets/js/core/auth.js"></script>
    <script src="/assets/js/core/api.js"></script>
    <script src="/assets/js/modules/auth/login.js"></script>

    <script>
        // AOS initialization for entrance effects
        document.addEventListener('DOMContentLoaded', () => {
            const wrapper = document.querySelector('.auth-wrapper');
            wrapper.style.opacity = '1';
        });
    </script>
</body>
</html>