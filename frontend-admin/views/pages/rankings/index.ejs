<!DOCTYPE html>
<html lang="pt-AO" data-theme="dark">
<head>
    <%- include('../../partials/head-meta', { title: 'Tiers Competitivos', moduleStyle: 'rankings' }) %>
</head>
<body>
    <div id="app-wrapper">
        <!-- Sidebar Navigation -->
        <%- include('../../partials/sidebar', { active: 'rankings' }) %>

        <div id="main-content" class="sidebar-transition">
            <!-- Top Navbar -->
            <%- include('../../partials/navbar') %>

            <main class="content-body">
                <!-- Breadcrumbs & Header -->
                <%- include('../../partials/breadcrumbs', { 
                    breadcrumbs: [
                        { name: 'Economia & Rankings', url: '#' },
                        { name: 'Tiers e Ligas', url: '/rankings' }
                    ] 
                }) %>

                <div class="section-header d-flex justify-content-between align-items-center mb-4">
                    <div>
                        <h2 class="text-main mb-1">Ecossistema Competitivo</h2>
                        <p class="text-muted small">Gestão de divisões, League Points (LP) e monitorização de temporadas oficiais.</p>
                    </div>
                    <div class="d-flex gap-2">
                        <button class="btn-oc btn-oc-outline" id="btn-refresh-rankings">
                            <i class="bi bi-arrow-clockwise me-2"></i> Sincronizar Liga
                        </button>
                    </div>
                </div>

                <!-- Season Status & My Rank Highlight -->
                <div class="tier-progress-card animate-up" data-aos="fade-up">
                    <div class="tier-visual-wrapper">
                        <!-- Default icon while loading -->
                        <img src="/assets/img/placeholders/tier-master.png" id="hero-tier-icon" class="tier-main-icon" alt="Tier Icon">
                        <span id="hero-tier-name" class="tier-label-hero tier-color-master">CARREGANDO...</span>
                    </div>
                    <div class="lp-progress-info">
                        <div class="lp-counter">
                            <div>
                                <small class="text-dim d-block uppercase fw-bold" style="font-size: 10px; letter-spacing: 1px;">Sua Pontuação de Liga</small>
                                <div class="lp-current" id="hero-lp-value">0 <span class="fs-5 text-muted">LP</span></div>
                            </div>
                            <div class="text-end">
                                <span class="lp-target" id="lp-next-tier-label">Próximo Tier: ---</span>
                                <div class="text-main fw-bold" id="lp-needed-value">-- LP restantes</div>
                            </div>
                        </div>
                        <div class="oc-lp-bar-track">
                            <div class="oc-lp-bar-fill" id="hero-lp-progress" style="width: 0%"></div>
                        </div>
                        <div class="d-flex justify-content-between align-items-center">
                            <div class="d-flex align-items-center gap-2">
                                <i class="bi bi-info-circle text-secondary"></i>
                                <span class="text-muted small">Posição Global: <strong class="text-main" id="hero-global-pos">#---</strong></span>
                            </div>
                            <span class="oc-badge badge-success">TEMPORADA 1 ACTIVADA</span>
                        </div>
                    </div>
                </div>

                <div class="row g-4">
                    <!-- Column: Elite Leaderboard -->
                    <div class="col-xl-8 col-lg-7">
                        <div class="oc-card p-0 overflow-hidden" data-aos="fade-up">
                            <div class="oc-card-header p-4 border-bottom border-secondary">
                                <h5 class="text-main fw-bold mb-0">Elite de Angola (Top 100)</h5>
                                <div class="d-flex gap-2">
                                    <div class="auth-input-group mb-0">
                                        <i class="bi bi-search"></i>
                                        <input type="text" id="rank-search" class="form-control form-control-sm bg-dark border-0" placeholder="Filtrar lendas...">
                                    </div>
                                </div>
                            </div>

                            <div id="rankings-loader" class="text-center py-5" style="display: none;">
                                <div class="spinner-custom mx-auto mb-3"></div>
                                <p class="text-muted small">Calculando posições competitivas...</p>
                            </div>

                            <div class="oc-table-container">
                                <table class="oc-table mb-0" id="rankings-table">
                                    <thead>
                                        <tr>
                                            <th class="text-center" style="width: 80px;">Posição</th>
                                            <th>Jogador</th>
                                            <th>Pontos de Liga</th>
                                            <th>Divisão</th>
                                            <th class="text-end pe-4">Acções</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <!-- Injetado via rankings.js -->
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>

                    <!-- Column: Demographics & Admin -->
                    <div class="col-xl-4 col-lg-5">
                        <!-- Tier Distribution Chart -->
                        <div class="oc-card mb-4" data-aos="fade-left">
                            <h6 class="text-main fw-bold mb-4">Demografia de Tiers</h6>
                            <div class="rank-distribution-panel">
                                <canvas id="chart-tier-distribution"></canvas>
                            </div>
                        </div>

                        <!-- Season Countdown & Reset -->
                        <div class="oc-card border-danger border-opacity-25" data-aos="fade-left" data-aos-delay="100">
                            <h6 class="text-danger fw-bold mb-3"><i class="bi bi-exclamation-triangle-fill me-2"></i>Encerramento de Temporada</h6>
                            <div class="season-control-box">
                                <span class="text-muted small">Tempo restante para o Reset:</span>
                                <span class="season-timer" id="season-countdown">14d 08h 22m</span>
                                <p class="text-dim small mb-4">O reset redistribui os prêmios da liga e reduz o LP dos jogadores de elite para o início da nova jornada.</p>
                                <button class="btn-oc btn-oc-outline text-danger w-100 btn-sm" id="btn-reset-season">
                                    <i class="bi bi-arrow-repeat me-2"></i> Forçar Reset Antecipado
                                </button>
                            </div>
                        </div>

                        <!-- Competitive Integrity Info -->
                        <div class="oc-card mt-4 bg-dark border-secondary border-opacity-50" data-aos="fade-up">
                            <h6 class="text-dim fw-bold small mb-2 uppercase">Integridade Competitiva</h6>
                            <p class="text-muted" style="font-size: 11px; line-height: 1.4;">
                                Jogadores detectados com <strong class="text-danger">Win-Trading</strong> ou uso de scripts terão seus LPs zerados e serão banidos permanentemente do modo ranqueado.
                            </p>
                        </div>
                    </div>
                </div>
            </main>

            <!-- Global Footer & Scripts -->
            <%- include('../../partials/footer', { moduleScript: 'rankings/rankings' }) %>
        </div>
    </div>
</body>
</html>