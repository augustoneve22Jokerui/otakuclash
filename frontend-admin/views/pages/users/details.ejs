<!DOCTYPE html>
<html lang="pt-AO" data-theme="dark">
<head>
    <%- include('../../partials/head-meta', { title: 'Detalhes do Utilizador', moduleStyle: 'users' }) %>
</head>
<body>
    <div id="app-wrapper">
        <!-- Sidebar Navigation -->
        <%- include('../../partials/sidebar', { active: 'users' }) %>

        <div id="main-content" class="sidebar-transition">
            <!-- Top Navbar -->
            <%- include('../../partials/navbar') %>

            <main class="content-body">
                <!-- Breadcrumbs & Header -->
                <%- include('../../partials/breadcrumbs', { 
                    breadcrumbs: [
                        { name: 'Administração', url: '#' },
                        { name: 'Gestão de Usuários', url: '/users' },
                        { name: 'Perfil Detalhado', url: '#' }
                    ] 
                }) %>

                <!-- Profile Header -->
                <div class="user-details-header animate-up" data-aos="fade-down">
                    <div class="user-cover-photo shadow-sm"></div>
                    <div class="user-profile-info-wrapper">
                        <img src="/assets/img/placeholders/avatar.png" id="display-avatar" class="user-main-avatar" alt="Avatar">
                        <div class="user-title-area flex-grow-1">
                            <h2 class="text-main fw-800 mb-0">
                                <span id="display-username">Carregando...</span>
                                <i class="bi bi-patch-check-fill text-info ms-2 shadow-sm" title="Utilizador Verificado"></i>
                            </h2>
                            <div class="d-flex align-items-center gap-3 mt-1">
                                <span class="text-muted small" id="display-email">---</span>
                                <span class="vr bg-secondary opacity-25"></span>
                                <div class="d-flex align-items-center gap-2">
                                    <span id="display-status-pulse" class="status-pulse-red"></span>
                                    <span class="text-dim small" id="display-status-text">Status Desconhecido</span>
                                </div>
                            </div>
                        </div>
                        <div class="user-actions-header d-flex gap-2">
                            <span id="display-role-badge" class="oc-badge badge-info">ROLE</span>
                            <button class="btn-oc btn-oc-outline btn-sm" id="btn-edit-user">
                                <i class="bi bi-pencil me-1"></i> Editar
                            </button>
                        </div>
                    </div>
                </div>

                <div id="details-loader" class="text-center py-5">
                    <div class="spinner-custom mx-auto mb-3"></div>
                    <p class="text-muted small">Mapeando dados do utilizador...</p>
                </div>

                <div class="row g-4 d-none" id="user-details-content">
                    <!-- Left Column: Core Identity & Gameplay -->
                    <div class="col-xl-8 col-lg-7">
                        <!-- Gameplay Stats Grid -->
                        <div class="user-stats-grid" data-aos="fade-up">
                            <div class="user-stat-box">
                                <span class="user-stat-label">Duelos</span>
                                <span class="user-stat-value" id="stats-matches">0</span>
                            </div>
                            <div class="user-stat-box">
                                <span class="user-stat-label">Vitórias</span>
                                <span class="user-stat-value text-success" id="stats-wins">0</span>
                            </div>
                            <div class="user-stat-box">
                                <span class="user-stat-label">Win Rate</span>
                                <span class="user-stat-value text-info" id="stats-winrate">0%</span>
                            </div>
                            <div class="user-stat-box">
                                <span class="user-stat-label">Clã / Guilda</span>
                                <span class="user-stat-value small text-truncate" id="stats-guild">Nenhum</span>
                            </div>
                        </div>

                        <!-- Progress & Leveling -->
                        <div class="oc-card mb-4" data-aos="fade-up">
                            <h6 class="text-main fw-bold mb-4"><i class="bi bi-star-fill text-warning me-2"></i>Progressão de Experiência</h6>
                            <div class="row align-items-center">
                                <div class="col-md-3 text-center">
                                    <div class="display-4 fw-800 text-main" id="prof-level">1</div>
                                    <span class="text-dim small uppercase">Nível Actual</span>
                                </div>
                                <div class="col-md-9">
                                    <div class="d-flex justify-content-between mb-2">
                                        <span class="text-dim small">Progresso do Nível</span>
                                        <span class="text-main fw-bold small" id="prof-xp">0 XP</span>
                                    </div>
                                    <div class="xp-bar-container">
                                        <div class="xp-bar-fill" style="width: 45%;"></div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Account Technical Info -->
                        <div class="oc-card" data-aos="fade-up">
                            <h6 class="text-main fw-bold mb-4">Informações Técnicas da Conta</h6>
                            <div class="row g-4">
                                <div class="col-md-6">
                                    <label class="oc-label">UUID Interno</label>
                                    <code class="d-block p-2 bg-dark rounded text-secondary small" id="acc-id">---</code>
                                </div>
                                <div class="col-md-6">
                                    <label class="oc-label">Data de Registo</label>
                                    <div class="text-main fw-500" id="acc-created">---</div>
                                </div>
                                <div class="col-md-6">
                                    <label class="oc-label">Estado de Verificação</label>
                                    <div id="acc-confirmed">---</div>
                                </div>
                                <div class="col-md-6">
                                    <label class="oc-label">Último Login (IPN)</label>
                                    <div class="text-main fw-500" id="acc-last-login">---</div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Right Column: Financial & Moderation -->
                    <div class="col-xl-4 col-lg-5">
                        <!-- Digital Wallet Summary -->
                        <div class="oc-card user-wallet-card mb-4" data-aos="fade-left">
                            <div class="d-flex justify-content-between align-items-center mb-4">
                                <h6 class="text-main fw-bold mb-0">Carteira Digital</h6>
                                <i class="bi bi-wallet2 text-success"></i>
                            </div>
                            <div class="mb-4">
                                <small class="text-dim d-block uppercase fw-bold" style="font-size: 10px;">Saldo Disponível</small>
                                <div class="balance-display mt-1" id="wallet-available">0.00 KZ</div>
                            </div>
                            <div class="mb-4">
                                <small class="text-dim d-block uppercase fw-bold" style="font-size: 10px;">Saldo Bloqueado (Apostas)</small>
                                <div class="text-main fw-bold" id="wallet-locked">0.00 KZ</div>
                            </div>
                            <div class="pt-3 border-top border-secondary d-flex justify-content-between align-items-center">
                                <span class="text-dim small">Saldo Bruto</span>
                                <span class="text-main fw-bold" id="wallet-total">0.00 KZ</span>
                            </div>
                            <button class="btn-oc btn-oc-primary btn-sm w-100 mt-4" id="btn-adjust-balance">
                                <i class="bi bi-pencil-square me-2"></i> Ajuste Administrativo
                            </button>
                        </div>

                        <!-- Quick Moderation Controls -->
                        <div class="oc-card mb-4" data-aos="fade-left" data-aos-delay="100">
                            <h6 class="text-main fw-bold mb-3">Moderação da Conta</h6>
                            <div class="d-grid gap-2">
                                <button class="btn-oc btn-oc-outline text-warning btn-sm" id="btn-toggle-status">
                                    <i class="bi bi-slash-circle me-2"></i> Suspender Utilizador
                                </button>
                                <button class="btn-oc btn-oc-outline text-info btn-sm" id="btn-change-role">
                                    <i class="bi bi-shield-lock me-2"></i> Alterar Permissões
                                </button>
                                <button class="btn-oc btn-oc-outline text-danger btn-sm" onclick="window.showAlert('Aviso', 'A remoção física de contas é restrita ao Super Administrador via Database.', 'warning')">
                                    <i class="bi bi-trash me-2"></i> Eliminar Registo
                                </button>
                            </div>
                        </div>

                        <!-- Recent Activity Snippet -->
                        <div class="oc-card" data-aos="fade-left" data-aos-delay="200">
                            <h6 class="text-main fw-bold mb-3">Últimas Transacções</h6>
                            <div class="user-activity-log" id="user-recent-tx">
                                <!-- Injetado via user-details.js -->
                            </div>
                            <a href="/transactions" class="text-primary small d-block text-center mt-3 text-decoration-none">Ver extrato completo</a>
                        </div>
                    </div>
                </div>
            </main>

            <!-- Global Footer & Scripts -->
            <%- include('../../partials/footer', { moduleScript: 'users/users-details' }) %>
        </div>
    </div>
</body>
</html>