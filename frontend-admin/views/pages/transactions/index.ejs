<!DOCTYPE html>
<html lang="pt-AO" data-theme="dark">
<head>
    <%- include('../../partials/head-meta', { title: 'Ledger de Transacções', moduleStyle: 'transactions' }) %>
</head>
<body>
    <div id="app-wrapper">
        <!-- Sidebar Navigation -->
        <%- include('../../partials/sidebar', { active: 'transactions' }) %>

        <div id="main-content" class="sidebar-transition">
            <!-- Top Navbar -->
            <%- include('../../partials/navbar') %>

            <main class="content-body">
                <!-- Breadcrumbs & Header -->
                <%- include('../../partials/breadcrumbs', { 
                    breadcrumbs: [
                        { name: 'Financeiro', url: '#' },
                        { name: 'Ledger de Transacções', url: '/transactions' }
                    ] 
                }) %>

                <div class="section-header d-flex justify-content-between align-items-center mb-4">
                    <div>
                        <h2 class="text-main mb-1">Livro de Registo Financeiro</h2>
                        <p class="text-muted small">Auditoria completa de movimentações, fluxos de caixa e integridade financeira da plataforma.</p>
                    </div>
                    <div class="d-flex gap-2">
                        <button class="btn-oc btn-oc-outline" id="btn-export-tx">
                            <i class="bi bi-file-earmark-excel me-2"></i> Exportar Ledger
                        </button>
                        <button class="btn-oc btn-oc-primary" id="btn-refresh-tx">
                            <i class="bi bi-arrow-clockwise"></i>
                        </button>
                    </div>
                </div>

                <!-- Financial Summary Bar -->
                <div class="transactions-summary-bar mb-4" data-aos="fade-up">
                    <div class="tx-stat-card border-start border-4 border-primary">
                        <span class="tx-stat-label">Volume Total (Sessão)</span>
                        <div class="tx-stat-value" id="session-volume-stat">0.00 KZ</div>
                    </div>
                    <div class="tx-stat-card border-start border-4 border-success">
                        <span class="tx-stat-label">Total Entradas (Créditos)</span>
                        <div class="tx-stat-value credit" id="total-credits-stat">0.00 KZ</div>
                    </div>
                    <div class="tx-stat-card border-start border-4 border-danger">
                        <span class="tx-stat-label">Total Saídas (Débitos)</span>
                        <div class="tx-stat-value debit" id="total-debits-stat">0.00 KZ</div>
                    </div>
                    <div class="tx-stat-card border-start border-4 border-info">
                        <span class="tx-stat-label">Transacções Pendentes</span>
                        <div class="tx-stat-value" id="pending-tx-count">0</div>
                    </div>
                </div>

                <!-- Advanced Filters -->
                <div class="tx-filters-wrapper shadow-sm" data-aos="fade-up">
                    <div class="row g-3">
                        <div class="col-xl-3 col-md-6">
                            <label class="oc-label">Tipo de Movimentação</label>
                            <select id="filter-tx-type" class="oc-input border-0 bg-dark">
                                <option value="">Todas as Categorias</option>
                                <option value="DEPOSIT">Depósitos (Gateway)</option>
                                <option value="WITHDRAWAL">Saques (Levantamentos)</option>
                                <option value="MATCH_REWARD">Prémios de Partida</option>
                                <option value="MATCH_ENTRY">Taxas de Entrada</option>
                                <option value="STORE_PURCHASE">Compras na Loja</option>
                                <option value="ADMIN_ADJUST">Ajustes Administrativos</option>
                                <option value="REFUND">Estornos</option>
                            </select>
                        </div>
                        <div class="col-xl-3 col-md-6">
                            <label class="oc-label">Estado</label>
                            <select id="filter-tx-status" class="oc-input border-0 bg-dark">
                                <option value="">Qualquer Estado</option>
                                <option value="COMPLETED">Concluídas</option>
                                <option value="PENDING">Pendentes / Em análise</option>
                                <option value="FAILED">Falhadas</option>
                                <option value="CANCELLED">Canceladas</option>
                                <option value="REFUNDED">Reembolsadas</option>
                            </select>
                        </div>
                        <div class="col-xl-4 col-md-8">
                            <label class="oc-label">Pesquisa por Usuário ou Referência</label>
                            <div class="auth-input-group mb-0">
                                <i class="bi bi-search"></i>
                                <input type="text" id="tx-search-input" class="form-control" placeholder="UUID, Username ou Cód. Referência...">
                            </div>
                        </div>
                        <div class="col-xl-2 col-md-4 d-flex align-items-end">
                            <button class="btn-oc btn-oc-secondary w-100" onclick="Transactions.loadTransactions()">
                                <i class="bi bi-filter-right me-2"></i> Filtrar
                            </button>
                        </div>
                    </div>
                </div>

                <!-- Transactions Ledger Table -->
                <div class="oc-card p-0 overflow-hidden" data-aos="fade-up">
                    <div id="tx-loader" class="text-center py-5" style="display: none;">
                        <div class="spinner-custom mx-auto mb-3"></div>
                        <p class="text-muted small">Auditando registos financeiros...</p>
                    </div>

                    <div class="oc-table-container">
                        <table class="oc-table mb-0" id="transactions-table">
                            <thead>
                                <tr>
                                    <th class="ps-4">ID Transacção</th>
                                    <th>Usuário / Carteira</th>
                                    <th>Tipo de Fluxo</th>
                                    <th>Montante</th>
                                    <th>Estado</th>
                                    <th>Descrição</th>
                                    <th class="text-end pe-4">Detalhes</th>
                                </tr>
                            </thead>
                            <tbody>
                                <!-- Injetado dinamicamente via transactions.js -->
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- Ledger Footer & Pagination -->
                <div class="d-flex justify-content-between align-items-center mt-4" data-aos="fade-up">
                    <div class="text-dim small">
                        Registos processados em conformidade com o Banco Nacional de Angola (BNA).
                    </div>
                    <div class="pagination-wrapper" id="tx-pagination">
                        <!-- Gerado via JS -->
                    </div>
                </div>
            </main>

            <!-- Global Footer & Scripts -->
            <%- include('../../partials/footer', { moduleScript: 'transactions/transactions' }) %>
        </div>
    </div>

    <!-- The Receipt View is handled via SweetAlert2 (as defined in transactions.js) -->
    <!-- This ensures it follows the 'Premium Receipt' visual style defined in transactions.css -->
</body>
</html>