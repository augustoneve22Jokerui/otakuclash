<!DOCTYPE html>
<html lang="pt-AO" data-theme="dark">
<head>
    <%- include('../../partials/head-meta', { title: 'Gestão de Pagamentos', moduleStyle: 'payments' }) %>
</head>
<body>
    <div id="app-wrapper">
        <!-- Sidebar Navigation -->
        <%- include('../../partials/sidebar', { active: 'payments' }) %>

        <div id="main-content" class="sidebar-transition">
            <!-- Top Navbar -->
            <%- include('../../partials/navbar') %>

            <main class="content-body">
                <!-- Breadcrumbs & Header -->
                <%- include('../../partials/breadcrumbs', { 
                    breadcrumbs: [
                        { name: 'Financeiro', url: '#' },
                        { name: 'Gateways de Pagamento', url: '/payments' }
                    ] 
                }) %>

                <div class="section-header d-flex justify-content-between align-items-center mb-4">
                    <div>
                        <h2 class="text-main mb-1">Gateways & Liquidação</h2>
                        <p class="text-muted small">Monitorização de fluxos de entrada, configuração de taxas e integração com a rede Multicaixa.</p>
                    </div>
                    <div class="d-flex gap-2">
                        <button class="btn-oc btn-oc-outline" id="btn-refresh-payments">
                            <i class="bi bi-arrow-clockwise me-2"></i> Sincronizar Transacções
                        </button>
                    </div>
                </div>

                <!-- Financial Health Overview -->
                <div class="payments-summary-grid mb-4" data-aos="fade-up">
                    <div class="financial-card">
                        <small class="text-dim uppercase fw-bold" style="font-size: 10px; letter-spacing: 1px;">Depósitos (Mês Actual)</small>
                        <div class="d-flex align-items-baseline gap-2 mt-2">
                            <span class="fs-3 fw-800 text-success" id="total-monthly-deposits">0.00</span>
                            <span class="text-muted small">AKZ</span>
                        </div>
                        <div class="risk-indicator">
                            <div class="risk-level-safe"></div>
                        </div>
                    </div>
                    <div class="financial-card">
                        <small class="text-dim uppercase fw-bold" style="font-size: 10px; letter-spacing: 1px;">Taxas Arrecadadas</small>
                        <div class="d-flex align-items-baseline gap-2 mt-2">
                            <span class="fs-3 fw-800 text-info" id="total-commissions">0.00</span>
                            <span class="text-muted small">AKZ</span>
                        </div>
                        <div class="mt-2 text-dim small">Média de 3.5% por operação</div>
                    </div>
                    <div class="financial-card">
                        <small class="text-dim uppercase fw-bold" style="font-size: 10px; letter-spacing: 1px;">Status da Rede EMIS</small>
                        <div class="d-flex align-items-center gap-3 mt-2">
                            <span class="status-pulse-green"></span>
                            <span class="fw-bold text-main">OPERACIONAL</span>
                        </div>
                        <div class="mt-2 text-muted small">Latência do Webhook: 1.2s</div>
                    </div>
                </div>

                <!-- Gateways Configuration Status -->
                <h5 class="text-main fw-bold mb-3"><i class="bi bi-cpu me-2 text-primary"></i>Módulos de Integração Ativos</h5>
                <div class="row gateway-grid mb-5" id="gateways-status-container" data-aos="fade-up">
                    <!-- Cards de Gateways (MCX, Unitel Money, etc) injetados via payments.js -->
                    <div class="col-12 text-center py-4">
                        <div class="spinner-custom mx-auto"></div>
                        <p class="text-muted mt-2 small">Verificando status dos provedores...</p>
                    </div>
                </div>

                <!-- Audit Table: Recent Payment Deposits -->
                <div class="section-header d-flex justify-content-between align-items-center mb-3" data-aos="fade-up">
                    <h5 class="text-main fw-bold mb-0">Auditoria de Depósitos Recentes</h5>
                    <div class="d-flex gap-2">
                        <select id="filter-payment-method" class="oc-input border-0 bg-dark py-1 px-3 small" style="width: auto;">
                            <option value="">Todos os Provedores</option>
                            <option value="MCX_EXPRESS">Multicaixa Express</option>
                            <option value="UNITEL_MONEY">Unitel Money</option>
                        </select>
                    </div>
                </div>

                <div class="oc-card p-0 overflow-hidden" data-aos="fade-up">
                    <div id="payments-loader" class="text-center py-5" style="display: none;">
                        <div class="spinner-border text-primary" role="status"></div>
                    </div>
                    <div class="oc-table-container">
                        <table class="oc-table mb-0" id="payments-table">
                            <thead>
                                <tr>
                                    <th class="ps-4">Referência / ID</th>
                                    <th>Usuário Beneficiário</th>
                                    <th>Valor Bruto</th>
                                    <th>Estado</th>
                                    <th>Data e Hora</th>
                                    <th class="text-end pe-4">Sync / Audit</th>
                                </tr>
                            </thead>
                            <tbody>
                                <!-- Injetado dinamicamente via loadPaymentTransactions() em payments.js -->
                            </tbody>
                        </table>
                    </div>
                </div>
            </main>

            <!-- Global Footer & Scripts -->
            <%- include('../../partials/footer', { moduleScript: 'payments/payments' }) %>
        </div>
    </div>

    <!-- Modal: Gateway Configuration (Admin Only) -->
    <div class="modal fade" id="gateway-config-modal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content shadow-lg border-secondary">
                <div class="modal-header border-secondary bg-main">
                    <h5 class="modal-title fw-bold">Parâmetros do Provedor</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body p-4">
                    <div class="alert alert-warning bg-dark border-warning border-opacity-25 mb-4">
                        <i class="bi bi-shield-lock-fill me-2"></i>
                        <small class="text-muted">A alteração destas chaves interrompe o processamento de pagamentos em tempo real.</small>
                    </div>
                    <form id="gateway-config-form">
                        <input type="hidden" id="config-gateway-id">
                        <div class="oc-input-group">
                            <label class="oc-label">Terminal ID (EMIS/MCX)</label>
                            <input type="text" class="oc-input" placeholder="Ex: 80001234">
                        </div>
                        <div class="oc-input-group">
                            <label class="oc-label">Chave Secreta (Webhook HMAC)</label>
                            <input type="password" class="oc-input" placeholder="••••••••••••••••">
                        </div>
                        <div class="oc-input-group mb-0">
                            <label class="oc-label">URL de Callback (IPN)</label>
                            <code class="d-block p-2 bg-black rounded text-info small">https://otakuclash.ao/api/v1/payments/webhook/mcx</code>
                        </div>
                    </form>
                </div>
                <div class="modal-footer border-secondary bg-main">
                    <button type="button" class="btn-oc btn-oc-outline" data-bs-dismiss="modal">Cancelar</button>
                    <button type="button" class="btn-oc btn-oc-primary" onclick="window.showAlert('Aviso', 'Acesso negado. Apenas o Super Administrador pode alterar chaves de API.', 'warning')">
                        <i class="bi bi-save me-2"></i> Salvar Credenciais
                    </button>
                </div>
            </div>
        </div>
    </div>
</body>
</html>