<!DOCTYPE html>
<html lang="pt-AO" data-theme="dark">
<head>
    <%- include('../../partials/head-meta', { title: 'Configurações Globais', moduleStyle: 'settings' }) %>
</head>
<body>
    <div id="app-wrapper">
        <!-- Sidebar Navigation -->
        <%- include('../../partials/sidebar', { active: 'settings' }) %>

        <div id="main-content" class="sidebar-transition">
            <!-- Top Navbar -->
            <%- include('../../partials/navbar') %>

            <main class="content-body">
                <!-- Breadcrumbs & Header -->
                <%- include('../../partials/breadcrumbs', { 
                    breadcrumbs: [
                        { name: 'Sistema & Segurança', url: '#' },
                        { name: 'Configurações', url: '/settings' }
                    ] 
                }) %>

                <div class="section-header d-flex justify-content-between align-items-center mb-4">
                    <div>
                        <h2 class="text-main mb-1">Configurações do Sistema</h2>
                        <p class="text-muted small">Gerencie os parâmetros globais, identidade visual e políticas operacionais da plataforma.</p>
                    </div>
                    <button type="submit" form="global-settings-form" class="btn-oc btn-oc-primary btn-save-settings">
                        <i class="bi bi-cloud-check me-2"></i> Salvar Alterações
                    </button>
                </div>

                <!-- Settings Navigation Tabs -->
                <div class="settings-tabs-wrapper mb-4" data-aos="fade-up">
                    <div class="settings-tab-item active" data-target="section-general">Geral</div>
                    <div class="settings-tab-item" data-target="section-platform">Plataforma</div>
                    <div class="settings-tab-item" data-target="section-security">Segurança</div>
                    <div class="settings-tab-item" data-target="section-notifications">Notificações</div>
                    <div class="settings-tab-item" data-target="section-payments">Pagamentos</div>
                    <div class="settings-tab-item" data-target="section-integrations">Integrações</div>
                    <div class="settings-tab-item" data-target="section-emails">E-mails</div>
                    <div class="settings-tab-item" data-target="section-logs">Logs</div>
                    <div class="settings-tab-item" data-target="section-system">Sistema</div>
                </div>

                <form id="global-settings-form">
                    <div class="settings-grid">
                        <!-- Left/Main Column: Settings Sections -->
                        <div class="settings-main-column" style="grid-column: span 2;">
                            
                            <!-- SECTION: GENERAL -->
                            <div id="section-general" class="settings-section animate-up">
                                <div class="row g-4">
                                    <!-- Platform Info -->
                                    <div class="col-md-12">
                                        <div class="settings-card">
                                            <div class="settings-card-header">
                                                <div class="settings-card-icon"><i class="bi bi-info-circle"></i></div>
                                                <h6 class="text-main fw-bold mb-0">Informações da Plataforma</h6>
                                            </div>
                                            <div class="row">
                                                <div class="col-md-12 mb-3">
                                                    <label class="oc-label">Nome da Plataforma</label>
                                                    <input type="text" name="app_name" id="app_name" class="oc-input" value="Otaku Clash Angola">
                                                </div>
                                                <div class="col-md-12 mb-3">
                                                    <label class="oc-label">Descrição (SEO / Meta)</label>
                                                    <textarea name="app_description" id="app_description" class="oc-input" rows="2">A maior plataforma de quizzes e batalhas de anime em Angola!</textarea>
                                                </div>
                                                <div class="col-md-6 mb-3">
                                                    <label class="oc-label">E-mail de Suporte</label>
                                                    <input type="email" name="support_email" id="support_email" class="oc-input" value="suporte@otakuclash.ao">
                                                </div>
                                                <div class="col-md-6 mb-3">
                                                    <label class="oc-label">URL da Plataforma</label>
                                                    <input type="url" name="app_url" id="app_url" class="oc-input" value="https://otakuclash.ao">
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- Appearance -->
                                    <div class="col-md-12">
                                        <div class="settings-card">
                                            <div class="settings-card-header">
                                                <div class="settings-card-icon"><i class="bi bi-palette"></i></div>
                                                <h6 class="text-main fw-bold mb-0">Configurações de Aparência</h6>
                                            </div>
                                            <div class="row g-4">
                                                <div class="col-md-6">
                                                    <label class="oc-label mb-3">Tema Padrão</label>
                                                    <div class="theme-selector-grid">
                                                        <div class="theme-preview-card" onclick="Settings.setTheme('light')">
                                                            <div class="theme-mock-ui theme-mock-light"></div>
                                                            <span class="small fw-bold">Claro</span>
                                                        </div>
                                                        <div class="theme-preview-card active" onclick="Settings.setTheme('dark')">
                                                            <div class="theme-mock-ui theme-mock-dark"></div>
                                                            <span class="small fw-bold">Escuro</span>
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="col-md-6">
                                                    <label class="oc-label mb-3">Cores de Identidade</label>
                                                    <div class="d-flex gap-3 mb-3">
                                                        <div class="flex-grow-1">
                                                            <small class="text-dim d-block mb-1">Cor Primária</small>
                                                            <div class="d-flex align-items-center gap-2">
                                                                <input type="color" name="appearance_primary_color" id="appearance_primary_color" class="form-control form-control-color bg-transparent border-0" value="#FF3B5C">
                                                                <code class="text-main small">#FF3B5C</code>
                                                            </div>
                                                        </div>
                                                        <div class="flex-grow-1">
                                                            <small class="text-dim d-block mb-1">Cor Secundária</small>
                                                            <div class="d-flex align-items-center gap-2">
                                                                <input type="color" name="appearance_secondary_color" id="appearance_secondary_color" class="form-control form-control-color bg-transparent border-0" value="#7C4DFF">
                                                                <code class="text-main small">#7C4DFF</code>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- Content & Pagination -->
                                    <div class="col-md-6">
                                        <div class="settings-card h-100">
                                            <div class="settings-card-header">
                                                <div class="settings-card-icon"><i class="bi bi-collection"></i></div>
                                                <h6 class="text-main fw-bold mb-0">Configurações de Conteúdo</h6>
                                            </div>
                                            <div class="settings-row-input">
                                                <div class="small">Itens por página padrão</div>
                                                <select name="content_items_per_page" id="content_items_per_page" class="oc-input py-1" style="width: 80px;">
                                                    <option value="10">10</option>
                                                    <option value="20" selected>20</option>
                                                    <option value="50">50</option>
                                                </select>
                                            </div>
                                            <div class="settings-row-input">
                                                <div class="small">Moderação Automática</div>
                                                <div class="form-check form-switch">
                                                    <input class="form-check-input" type="checkbox" name="content_auto_moderation" id="content_auto_moderation" checked>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- Storage & Uploads -->
                                    <div class="col-md-6">
                                        <div class="settings-card h-100">
                                            <div class="settings-card-header">
                                                <div class="settings-card-icon"><i class="bi bi-cloud-upload"></i></div>
                                                <h6 class="text-main fw-bold mb-0">Uploads & Storage</h6>
                                            </div>
                                            <div class="settings-row-input">
                                                <div class="small">Tamanho máximo de arquivo</div>
                                                <select name="upload_max_size" id="upload_max_size" class="oc-input py-1" style="width: 100px;">
                                                    <option value="2">2 MB</option>
                                                    <option value="5">5 MB</option>
                                                    <option value="10" selected>10 MB</option>
                                                </select>
                                            </div>
                                            <div class="settings-row-input">
                                                <div class="small">Qualidade de imagem</div>
                                                <select name="upload_image_quality" id="upload_image_quality" class="oc-input py-1" style="width: 120px;">
                                                    <option value="high">Alta (85%)</option>
                                                    <option value="medium">Média (70%)</option>
                                                </select>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- OTHER SECTIONS (Placeholder logic for JS switching) -->
                            <div id="section-platform" class="settings-section d-none animate-up">
                                <div class="oc-card">
                                    <h6 class="text-main fw-bold mb-4">Parâmetros Operacionais</h6>
                                    <div class="settings-row-input">
                                        <div>
                                            <span class="text-main d-block small">Plataforma Online</span>
                                            <span class="text-muted" style="font-size: 11px;">Torna o frontend acessível aos usuários.</span>
                                        </div>
                                        <div class="form-check form-switch">
                                            <input class="form-check-input" type="checkbox" name="system_online" id="system_online" checked>
                                        </div>
                                    </div>
                                    <div class="settings-row-input">
                                        <div>
                                            <span class="text-main d-block small">Modo Manutenção</span>
                                            <span class="text-muted" style="font-size: 11px;">Exibe tela de manutenção para não-admins.</span>
                                        </div>
                                        <div class="form-check form-switch">
                                            <input class="form-check-input" type="checkbox" name="system_maintenance" id="system_maintenance">
                                        </div>
                                    </div>
                                </div>
                            </div>

                        </div>

                        <!-- Right Column: System Info & Actions -->
                        <div class="settings-side-column">
                            <div class="oc-card mb-4">
                                <h6 class="text-main fw-bold mb-3">Informações do Sistema</h6>
                                <div class="system-info-list">
                                    <div class="info-item">
                                        <span class="info-label">Versão</span>
                                        <span class="info-value">v<%= version %></span>
                                    </div>
                                    <div class="info-item">
                                        <span class="info-label">Ambiente</span>
                                        <span class="info-value text-success">Produção</span>
                                    </div>
                                    <div class="info-item">
                                        <span class="info-label">Servidor</span>
                                        <span class="info-value"><span class="status-dot-online"></span> Online</span>
                                    </div>
                                    <div class="info-item">
                                        <span class="info-label">Uptime</span>
                                        <span class="info-value" id="display-uptime">15 dias, 8h 24m</span>
                                    </div>
                                </div>
                            </div>

                            <div class="oc-card">
                                <h6 class="text-main fw-bold mb-3">Ações Rápidas</h6>
                                <button type="button" class="quick-action-btn" data-setting-action="clear-cache">
                                    <i class="bi bi-lightning-charge"></i> Limpar Cache
                                </button>
                                <button type="button" class="quick-action-btn" data-setting-action="reindex-search">
                                    <i class="bi bi-search"></i> Reindexar Busca
                                </button>
                                <button type="button" class="quick-action-btn" data-setting-action="db-backup">
                                    <i class="bi bi-database-down"></i> Backup do Banco
                                </button>
                                <button type="button" class="quick-action-btn text-danger" onclick="Auth.logout()">
                                    <i class="bi bi-box-arrow-right"></i> Sair do Painel
                                </button>
                            </div>
                        </div>
                    </div>
                </form>
            </main>

            <!-- Global Footer & Scripts -->
            <%- include('../../partials/footer', { moduleScript: 'settings/settings' }) %>
        </div>
    </div>

    <!-- Technical Overlay Loader -->
    <div id="settings-loader" class="position-fixed top-0 start-0 w-100 h-100 bg-dark bg-opacity-75 d-flex align-items-center justify-content-center" style="display: none; z-index: 2000;">
        <div class="text-center">
            <div class="spinner-custom mx-auto mb-3"></div>
            <p class="text-white fw-bold">Sincronizando configurações...</p>
        </div>
    </div>
</body>
</html>