<!DOCTYPE html>
<html lang="pt-AO" data-theme="dark">
<head>
    <%- include('../../partials/head-meta', { title: 'Banco de Questões', moduleStyle: 'questions' }) %>
</head>
<body>
    <div id="app-wrapper">
        <!-- Sidebar Navigation -->
        <%- include('../../partials/sidebar', { active: 'questions' }) %>

        <div id="main-content" class="sidebar-transition">
            <!-- Top Navbar -->
            <%- include('../../partials/navbar') %>

            <main class="content-body">
                <!-- Breadcrumbs & Header -->
                <%- include('../../partials/breadcrumbs', { 
                    breadcrumbs: [
                        { name: 'Catálogo', url: '#' },
                        { name: 'Questões', url: '/questions' }
                    ] 
                }) %>

                <div class="section-header d-flex justify-content-between align-items-center mb-4">
                    <div>
                        <h2 class="text-main mb-1">Curadoria de Quiz</h2>
                        <p class="text-muted small">Gerencie o acervo de perguntas, alternativas e níveis de dificuldade para todos os modos de jogo.</p>
                    </div>
                    <div class="d-flex gap-2">
                        <button class="btn-oc btn-oc-outline" id="btn-export-questions">
                            <i class="bi bi-file-earmark-arrow-down me-2"></i> Exportar Banco
                        </button>
                        <a href="/questions/new" class="btn-oc btn-oc-primary">
                            <i class="bi bi-patch-plus-fill me-2"></i> Nova Questão
                        </a>
                    </div>
                </div>

                <!-- Content KPIs -->
                <div class="row g-4 mb-4" data-aos="fade-up">
                    <div class="col-md-3">
                        <div class="oc-card q-meta-card h-100">
                            <span class="q-meta-label">Total de Perguntas</span>
                            <span class="fs-3 fw-800 text-main" id="total-questions-count">0</span>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="oc-card q-meta-card h-100 border-info border-opacity-25">
                            <span class="q-meta-label">Média de Pontos</span>
                            <span class="fs-3 fw-800 text-info">15.5</span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="oc-card h-100 bg-dark border-secondary border-opacity-50 d-flex align-items-center justify-content-around">
                            <div class="text-center">
                                <span class="q-meta-label">Dificuldade Fácil</span>
                                <span class="text-success fw-bold">35%</span>
                            </div>
                            <div class="vr bg-secondary opacity-25"></div>
                            <div class="text-center">
                                <span class="q-meta-label">Dificuldade Média</span>
                                <span class="text-warning fw-bold">40%</span>
                            </div>
                            <div class="vr bg-secondary opacity-25"></div>
                            <div class="text-center">
                                <span class="q-meta-label">Dificuldade Épica</span>
                                <span class="text-danger fw-bold">25%</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Advanced Filter Bar -->
                <div class="questions-filter-bar shadow-sm" data-aos="fade-up">
                    <div class="row g-3">
                        <div class="col-xl-4 col-lg-5">
                            <label class="oc-label">Vínculo por Obra (Anime)</label>
                            <select id="filter-anime" class="oc-input border-0 bg-dark">
                                <option value="">Todos os Animes do Catálogo</option>
                                <!-- Populado via loadFilterData em questions-list.js -->
                            </select>
                        </div>
                        <div class="col-xl-2 col-lg-3">
                            <label class="oc-label">Categoria</label>
                            <select id="filter-category" class="oc-input border-0 bg-dark">
                                <option value="">Todas as Categorias</option>
                                <option value="ANIME">Geral do Anime</option>
                                <option value="CHARACTER">Personagens</option>
                                <option value="PLOT">Enredo / História</option>
                                <option value="MUSIC">Trilha Sonora</option>
                            </select>
                        </div>
                        <div class="col-xl-2 col-lg-4">
                            <label class="oc-label">Dificuldade</label>
                            <select id="filter-difficulty" class="oc-input border-0 bg-dark">
                                <option value="">Níveis (1 a 5)</option>
                                <option value="1">Level 1 (Novato)</option>
                                <option value="2">Level 2 (Iniciado)</option>
                                <option value="3">Level 3 (Combatente)</option>
                                <option value="4">Level 4 (Mestre)</option>
                                <option value="5">Level 5 (Lenda)</option>
                            </select>
                        </div>
                        <div class="col-xl-4 col-lg-12 d-flex align-items-end">
                            <div class="d-flex gap-2 w-100">
                                <div class="auth-input-group mb-0 flex-grow-1">
                                    <i class="bi bi-search"></i>
                                    <input type="text" id="question-search-input" class="form-control" placeholder="Buscar no enunciado...">
                                </div>
                                <button class="btn-oc btn-oc-outline" id="btn-refresh-questions">
                                    <i class="bi bi-arrow-clockwise"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Questions Registry Table -->
                <div class="oc-card p-0 overflow-hidden" data-aos="fade-up">
                    <div id="questions-loader" class="text-center py-5" style="display: none;">
                        <div class="spinner-custom mx-auto mb-3"></div>
                        <p class="text-muted small">Consultando banco de dados central...</p>
                    </div>

                    <div class="oc-table-container">
                        <table class="oc-table mb-0" id="questions-table">
                            <thead>
                                <tr>
                                    <th class="ps-4">UID</th>
                                    <th>Enunciado e Vínculo</th>
                                    <th>Obra / Categoria</th>
                                    <th>Dificuldade</th>
                                    <th>Data</th>
                                    <th class="text-end pe-4">Gestão</th>
                                </tr>
                            </thead>
                            <tbody>
                                <!-- Injetado dinamicamente via questions-list.js -->
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- Table Footer & Pagination -->
                <div class="d-flex justify-content-between align-items-center mt-4" data-aos="fade-up">
                    <div class="text-dim small">
                        Padrão operacional: 10 registos por página
                    </div>
                    <div class="pagination-wrapper" id="questions-pagination">
                        <!-- Gerado via JS -->
                    </div>
                </div>
            </main>

            <!-- Global Footer & Scripts -->
            <%- include('../../partials/footer', { moduleScript: 'questions/questions-list' }) %>
        </div>
    </div>
</body>
</html>