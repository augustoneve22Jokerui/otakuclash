<!DOCTYPE html>
<html lang="pt-AO" data-theme="dark">
<head>
    <%- include('../../partials/head-meta', { title: 'Monitorização de Duelos', moduleStyle: 'matches' }) %>
</head>
<body>
    <div id="app-wrapper">
        <!-- Sidebar Navigation -->
        <%- include('../../partials/sidebar', { active: 'matches' }) %>

        <div id="main-content" class="sidebar-transition">
            <!-- Top Navbar -->
            <%- include('../../partials/navbar') %>

            <main class="content-body">
                <!-- Breadcrumbs & Header -->
                <%- include('../../partials/breadcrumbs', { 
                    breadcrumbs: [
                        { name: 'Arena & Competição', url: '#' },
                        { name: 'Duelos 1v1', url: '/matches' }
                    ] 
                }) %>

                <div class="section-header d-flex justify-content-between align-items-center mb-4">
                    <div>
                        <h2 class="text-main mb-1">Arena em Tempo Real</h2>
                        <p class="text-muted small">Supervisão técnica de combates directos, monitorização de scores e integridade de conexões.</p>
                    </div>
                    <div class="d-flex gap-2">
                        <div class="live-indicator">
                            <span class="live-dot"></span>
                            <span>Live Monitor</span>
                        </div>
                        <button class="btn-oc btn-oc-primary" id="btn-refresh-matches">
                            <i class="bi bi-arrow-clockwise"></i>
                        </button>
                    </div>
                </div>

                <!-- Arena Global Metrics -->
                <div class="row g-4 mb-4" data-aos="fade-up">
                    <div class="col-md-3">
                        <div class="oc-card stat-card hover-lift primary">
                            <div class="stat-card-icon"><i class="bi bi-lightning-fill"></i></div>
                            <div class="stat-card-value" id="live-matches-count">0</div>
                            <div class="stat-card-label">Duelos Activos</div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="oc-card stat-card hover-lift">
                            <div class="stat-card-icon"><i class="bi bi-people"></i></div>
                            <div class="stat-card-value" id="players-in-combat">0</div>
                            <div class="stat-card-label">Em Combate</div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="oc-card stat-card hover-lift secondary">
                            <div class="stat-card-icon"><i class="bi bi-cash-stack"></i></div>
                            <div class="stat-card-value" id="volume-in-play">0 KZ</div>
                            <div class="stat-card-label">Volume em Apostas</div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="oc-card stat-card hover-lift">
                            <div class="stat-card-icon text-warning"><i class="bi bi-clock-history"></i></div>
                            <div class="stat-card-value">--:--</div>
                            <div class="stat-card-label">Média de Duração</div>
                        </div>
                    </div>
                </div>

                <!-- Arena Filters -->
                <div class="match-filters-wrapper mb-4" data-aos="fade-up">
                    <div class="d-flex align-items-center gap-3 flex-wrap flex-grow-1">
                        <div class="filter-group">
                            <label class="oc-label small uppercase fw-bold mb-2">Modo de Jogo</label>
                            <select id="filter-match-type" class="oc-input border-0 bg-dark py-1">
                                <option value="">Todos os Modos</option>
                                <option value="1V1_DUEL">Duelo 1v1</option>
                                <option value="QUICK_PLAY">Partida Rápida</option>
                                <option value="BLITZ">Modo Blitz</option>
                                <option value="SURVIVAL">Sobrevivência</option>
                            </select>
                        </div>
                        <div class="filter-group">
                            <label class="oc-label small uppercase fw-bold mb-2">Escala de Aposta</label>
                            <select id="filter-bet-range" class="oc-input border-0 bg-dark py-1">
                                <option value="">Qualquer Valor</option>
                                <option value="free">Gratuito</option>
                                <option value="low">Até 1.000 KZ</option>
                                <option value="mid">1.000 - 5.000 KZ</option>
                                <option value="high">Acima de 5.000 KZ</option>
                            </select>
                        </div>
                    </div>
                    <div class="vr bg-secondary opacity-25 d-none d-md-block"></div>
                    <div class="search-match-box">
                        <label class="oc-label small uppercase fw-bold mb-2">Localizar por Código</label>
                        <div class="input-group">
                            <input type="text" class="form-control bg-dark border-0 text-white" placeholder="Ex: #K7B2X9" id="search-room-code">
                            <button class="btn btn-primary" type="button"><i class="bi bi-search"></i></button>
                        </div>
                    </div>
                </div>

                <!-- Matches Live Grid -->
                <div id="matches-loader" class="text-center py-5">
                    <div class="spinner-custom mx-auto mb-3"></div>
                    <p class="text-muted small">Sintonizando frequências de combate...</p>
                </div>

                <div class="row matches-monitor-grid" id="matches-monitor-grid">
                    <!-- Cards injected in real-time via matches-monitor.js -->
                </div>

                <!-- Arena Empty State -->
                <div class="arena-empty-state d-none" id="arena-empty-state">
                    <div class="arena-empty-icon">
                        <i class="bi bi-controller"></i>
                    </div>
                    <h4 class="text-main fw-bold">Silêncio na Arena</h4>
                    <p class="text-muted mx-auto" style="max-width: 400px;">Neste momento não existem duelos activos. O monitor actualizará automaticamente assim que um novo combate for detectado via Socket.IO.</p>
                </div>
            </main>

            <!-- Global Footer & Real-time Scripts -->
            <%- include('../../partials/footer', { moduleScript: 'matches/matches-monitor' }) %>
        </div>
    </div>

    <!-- Alert Sound for New Matches (Optional/Hidden) -->
    <audio id="match-start-sound" src="/assets/sounds/match-start.mp3" preload="auto"></audio>

    <script>
        // AOS adjustment for dynamic grid
        document.addEventListener('DOMContentLoaded', () => {
            const grid = document.getElementById('matches-monitor-grid');
            const observer = new MutationObserver(() => {
                AOS.refresh();
            });
            observer.observe(grid, { childList: true });
        });
    </script>
</body>
</html>