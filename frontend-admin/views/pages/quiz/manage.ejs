<!DOCTYPE html>
<html lang="pt-AO" data-theme="dark">
<head>
    <%- include('../../partials/head-meta', { title: 'Configurações de Quiz', moduleStyle: 'quiz' }) %>
</head>
<body>
    <div id="app-wrapper">
        <!-- Sidebar Navigation -->
        <%- include('../../partials/sidebar', { active: 'quiz' }) %>

        <div id="main-content" class="sidebar-transition">
            <!-- Top Navbar -->
            <%- include('../../partials/navbar') %>

            <main class="content-body">
                <!-- Breadcrumbs & Header -->
                <%- include('../../partials/breadcrumbs', { 
                    breadcrumbs: [
                        { name: 'Arena & Competição', url: '#' },
                        { name: 'Modos de Quiz', url: '/quiz' }
                    ] 
                }) %>

                <div class="section-header d-flex justify-content-between align-items-center mb-4">
                    <div>
                        <h2 class="text-main mb-1">Configuração de Gameplay</h2>
                        <p class="text-muted small">Ajuste as regras globais, pontuações e monitore o desempenho das sessões individuais.</p>
                    </div>
                    <div class="d-flex gap-2">
                        <button class="btn-oc btn-oc-outline text-warning" id="btn-cleanup-sessions">
                            <i class="bi bi-lightning-fill me-2"></i> Limpar Sessões Órfãs
                        </button>
                    </div>
                </div>

                <!-- Quiz Performance KPIs -->
                <div class="quiz-sessions-overview mb-4" data-aos="fade-up">
                    <div class="quiz-stat-card">
                        <div class="quiz-stat-icon"><i class="bi bi-play-circle-fill"></i></div>
                        <div>
                            <small class="text-dim d-block">Sessões Totais</small>
                            <span class="fs-4 fw-800 text-main" id="stat-total-sessions">0</span>
                        </div>
                    </div>
                    <div class="quiz-stat-card">
                        <div class="quiz-stat-icon" style="color: var(--success); background: rgba(0, 209, 255, 0.1);"><i class="bi bi-check-all"></i></div>
                        <div>
                            <small class="text-dim d-block">Taxa de Conclusão</small>
                            <span class="fs-4 fw-800 text-main">87.4%</span>
                        </div>
                    </div>
                    <div class="quiz-stat-card">
                        <div class="quiz-stat-icon" style="color: var(--primary-color); background: rgba(255, 59, 92, 0.1);"><i class="bi bi-stopwatch"></i></div>
                        <div>
                            <small class="text-dim d-block">Tempo Médio Resposta</small>
                            <span class="fs-4 fw-800 text-main">6.2s</span>
                        </div>
                    </div>
                    <div class="quiz-stat-card">
                        <div class="quiz-stat-icon" style="color: var(--warning); background: rgba(255, 171, 45, 0.1);"><i class="bi bi-fire"></i></div>
                        <div>
                            <small class="text-dim d-block">Recorde Semanal</small>
                            <span class="fs-4 fw-800 text-main">1.250 pts</span>
                        </div>
                    </div>
                </div>

                <div class="row g-4">
                    <!-- Column: Global Rules & Logic -->
                    <div class="col-xl-5 col-lg-6">
                        <div class="oc-card h-100" data-aos="fade-right">
                            <div class="d-flex justify-content-between align-items-center mb-4">
                                <h5 class="text-main fw-bold mb-0"><i class="bi bi-sliders me-2 text-primary"></i>Regras do Jogo</h5>
                                <span class="oc-badge badge-soft-primary">Global Config</span>
                            </div>

                            <form id="quiz-settings-form">
                                <div class="quiz-settings-wrapper p-0 border-0">
                                    <!-- Setting: Base Points -->
                                    <div class="setting-row">
                                        <div class="setting-info">
                                            <span class="setting-title">Pontos por Acerto</span>
                                            <span class="setting-desc">Valor base de pontos concedidos para cada resposta correcta em nível normal.</span>
                                        </div>
                                        <div style="width: 100px;">
                                            <input type="number" id="base_points" name="base_points" class="oc-input text-center" value="10">
                                        </div>
                                    </div>

                                    <!-- Setting: Speed Bonus -->
                                    <div class="setting-row">
                                        <div class="setting-info">
                                            <span class="setting-title">Bónus de Velocidade</span>
                                            <span class="setting-desc">Tempo limite (segundos) para dobrar o ganho de XP por resposta.</span>
                                        </div>
                                        <div style="width: 100px;">
                                            <input type="number" id="bonus_speed_threshold" name="speed_threshold" class="oc-input text-center" value="5">
                                        </div>
                                    </div>

                                    <!-- Setting: Max Questions -->
                                    <div class="setting-row">
                                        <div class="setting-info">
                                            <span class="setting-title">Questões por Rodada</span>
                                            <span class="setting-desc">Quantidade de perguntas geradas por padrão em uma sessão de Quick Play.</span>
                                        </div>
                                        <div style="width: 100px;">
                                            <input type="number" id="max_questions_solo" name="max_questions" class="oc-input text-center" value="10">
                                        </div>
                                    </div>

                                    <!-- Setting: Cooldown -->
                                    <div class="setting-row">
                                        <div class="setting-info">
                                            <span class="setting-title">Intervalo de Reentrada</span>
                                            <span class="setting-desc">Tempo de espera em minutos para iniciar um novo quiz após conclusão.</span>
                                        </div>
                                        <div style="width: 100px;">
                                            <input type="number" id="cooldown_between_quizzes" name="cooldown" class="oc-input text-center" value="0">
                                        </div>
                                    </div>
                                </div>

                                <div class="mt-4 pt-3 border-top border-secondary">
                                    <button type="submit" class="btn-oc btn-oc-primary w-100" id="btn-save-settings">
                                        <i class="bi bi-cloud-check me-2"></i> Aplicar Regras Globais
                                    </button>
                                </div>
                            </form>
                        </div>
                    </div>

                    <!-- Column: Recent Activity Monitoring -->
                    <div class="col-xl-7 col-lg-6">
                        <div class="oc-card h-100" data-aos="fade-left">
                            <div class="d-flex justify-content-between align-items-center mb-4">
                                <h5 class="text-main fw-bold mb-0">Monitor de Sessões Recentes</h5>
                                <button class="btn-oc btn-oc-outline btn-sm" id="btn-refresh-sessions">
                                    <i class="bi bi-arrow-clockwise"></i>
                                </button>
                            </div>

                            <div id="sessions-loader" class="text-center py-5" style="display: none;">
                                <div class="spinner-border text-primary" role="status"></div>
                            </div>

                            <div class="oc-table-container">
                                <table class="oc-table mb-0" id="quiz-sessions-table">
                                    <thead>
                                        <tr>
                                            <th>Sessão / Data</th>
                                            <th>Usuário</th>
                                            <th>Modo</th>
                                            <th>Anime</th>
                                            <th>Pontos</th>
                                            <th class="text-end">Análise</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <!-- Populado dinamicamente via quiz-manage.js -->
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Game Modes Management Section -->
                <div class="mt-5" data-aos="fade-up">
                    <h5 class="text-main fw-bold mb-4">Módulos de Jogo Activos</h5>
                    <div class="row g-4">
                        <div class="col-md-3">
                            <div class="oc-card text-center">
                                <span class="oc-badge mode-badge-blitz mb-3">BLITZ</span>
                                <p class="text-muted small mb-0">5 Questões rápidas. Foco em velocidade extrema.</p>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="oc-card text-center">
                                <span class="oc-badge mode-badge-survival mb-3">SOBREVIVÊNCIA</span>
                                <p class="text-muted small mb-0">Acertar até errar. Sem limite de questões.</p>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="oc-card text-center">
                                <span class="oc-badge mode-badge-practice mb-3">TREINO</span>
                                <p class="text-muted small mb-0">Sem ranking. Questões focadas por anime.</p>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="oc-card text-center">
                                <span class="oc-badge badge-info mb-3">QUICK PLAY</span>
                                <p class="text-muted small mb-0">Modo padrão equilibrado. 10 questões.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </main>

            <!-- Global Footer & Scripts -->
            <%- include('../../partials/footer', { moduleScript: 'quiz/quiz-manage' }) %>
        </div>
    </div>
</body>
</html>