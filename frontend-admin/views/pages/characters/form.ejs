<!DOCTYPE html>
<html lang="pt-AO" data-theme="dark">
<head>
    <%- include('../../partials/head-meta', { title: (typeof charId !== 'undefined' ? 'Editar Personagem' : 'Novo Personagem'), moduleStyle: 'characters' }) %>
</head>
<body>
    <div id="app-wrapper">
        <!-- Sidebar Navigation -->
        <%- include('../../partials/sidebar', { active: 'characters' }) %>

        <div id="main-content" class="sidebar-transition">
            <!-- Top Navbar -->
            <%- include('../../partials/navbar') %>

            <main class="content-body">
                <!-- Breadcrumbs & Header -->
                <%- include('../../partials/breadcrumbs', { 
                    breadcrumbs: [
                        { name: 'Catálogo', url: '#' },
                        { name: 'Personagens', url: '/characters' },
                        { name: (typeof charId !== 'undefined' ? 'Editar Registro' : 'Novo Registro'), url: '#' }
                    ] 
                }) %>

                <div class="section-header d-flex justify-content-between align-items-center mb-4">
                    <div>
                        <h2 class="text-main mb-1"><%= (typeof charId !== 'undefined' ? 'Editar Personagem' : 'Adicionar Personagem') %></h2>
                        <p class="text-muted small">Gerencie os detalhes biográficos e o vínculo do personagem com a obra original.</p>
                    </div>
                    <button type="button" class="btn-oc btn-oc-outline" onclick="window.location.href='/characters'">
                        <i class="bi bi-arrow-left me-2"></i> Voltar à Lista
                    </button>
                </div>

                <div class="row g-4">
                    <!-- Column: Main Form -->
                    <div class="col-xl-8 col-lg-7">
                        <div class="oc-card" data-aos="fade-up">
                            <form id="character-form-detailed">
                                <input type="hidden" id="char-id" value="<%= typeof charId !== 'undefined' ? charId : '' %>">
                                
                                <div class="row">
                                    <div class="col-md-8">
                                        <div class="oc-input-group">
                                            <label class="oc-label" for="name">Nome Completo do Personagem</label>
                                            <input type="text" id="name" name="name" class="oc-input" required placeholder="Ex: Roronoa Zoro">
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="oc-input-group">
                                            <label class="oc-label" for="mal_id">MAL ID (Referência)</label>
                                            <input type="number" id="mal_id" name="mal_id" class="oc-input" placeholder="Ex: 62">
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-12">
                                        <div class="oc-input-group">
                                            <label class="oc-label" for="anime_id">Anime Vinculado</label>
                                            <select id="anime_id" name="anime_id" class="oc-input" required>
                                                <option value="">Carregando catálogo de animes...</option>
                                                <!-- Populado via API -->
                                            </select>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="oc-input-group">
                                            <label class="oc-label" for="role">Papel na Obra</label>
                                            <select id="role" name="role" class="oc-input">
                                                <option value="Main">Protagonista / Principal</option>
                                                <option value="Supporting">Coadjuvante / Suporte</option>
                                                <option value="Antagonist">Antagonista / Vilão</option>
                                            </select>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="oc-input-group">
                                            <label class="oc-label" for="imageUrl">URL da Imagem de Perfil</label>
                                            <input type="url" id="imageUrl" name="imageUrl" class="oc-input" required placeholder="https://cdn.myanimelist.net/...">
                                        </div>
                                    </div>
                                </div>

                                <div class="oc-input-group mb-0">
                                    <label class="oc-label" for="about">Biografia / Sobre (Wiki)</label>
                                    <textarea id="about" name="about" class="oc-input char-bio-box" rows="10" placeholder="Descreva as habilidades, personalidade e história do personagem..."></textarea>
                                </div>

                                <div class="mt-4 pt-3 border-top border-secondary d-flex gap-2">
                                    <button type="submit" class="btn-oc btn-oc-primary flex-grow-1" id="btn-save-character">
                                        <i class="bi bi-cloud-check me-2"></i> Confirmar Alterações
                                    </button>
                                </div>
                            </form>
                        </div>
                    </div>

                    <!-- Column: Preview & Metadata -->
                    <div class="col-xl-4 col-lg-5">
                        <!-- Profile Preview Card -->
                        <div class="oc-card mb-4 text-center" data-aos="fade-left">
                            <h6 class="text-main fw-bold mb-3">Pré-visualização do Avatar</h6>
                            <div class="char-avatar-preview-wrapper mb-3">
                                <img src="/assets/img/placeholders/character.png" id="char-preview" class="char-detail-img shadow-lg" alt="Character Preview">
                            </div>
                            <div class="mt-3">
                                <span id="preview-role-badge" class="oc-badge badge-role-main">PAPEL</span>
                            </div>
                        </div>

                        <!-- Technical Info & Stats -->
                        <div class="oc-card mb-4" data-aos="fade-left" data-aos-delay="100">
                            <h6 class="text-main fw-bold mb-3"><i class="bi bi-graph-up me-2 text-primary"></i>Métricas de Jogo</h6>
                            <div class="list-group list-group-flush bg-transparent">
                                <div class="list-group-item bg-transparent border-secondary px-0 d-flex justify-content-between align-items-center">
                                    <span class="text-dim small">Questões que o citam</span>
                                    <span class="text-main fw-bold" id="count-related-questions">0</span>
                                </div>
                                <div class="list-group-item bg-transparent border-secondary px-0 d-flex justify-content-between align-items-center">
                                    <span class="text-dim small">Taxa de Acerto (Solo)</span>
                                    <span class="text-success fw-bold" id="avg-success-rate">0%</span>
                                </div>
                                <div class="list-group-item bg-transparent border-0 px-0 d-flex justify-content-between align-items-center">
                                    <span class="text-dim small">Popularidade</span>
                                    <span class="text-warning fw-bold"><i class="bi bi-heart-fill me-1"></i> <span id="popularity-rank">#--</span></span>
                                </div>
                            </div>
                        </div>

                        <!-- System Audit Card -->
                        <div class="oc-card bg-dark border-secondary border-opacity-50" data-aos="fade-left" data-aos-delay="200">
                            <h6 class="text-dim fw-bold small mb-3 uppercase">Informações do Sistema</h6>
                            <div class="small text-muted mb-2">
                                <i class="bi bi-info-circle me-2"></i> ID Local: <code class="text-secondary" id="display-local-id">N/A</code>
                            </div>
                            <div class="small text-muted">
                                <i class="bi bi-clock-history me-2"></i> Criado em: <span id="created-at-display" class="text-main">--/--/----</span>
                            </div>
                        </div>
                    </div>
                </div>
            </main>

            <!-- Global Footer & Scripts -->
            <%- include('../../partials/footer', { moduleScript: 'characters/characters' }) %>
        </div>
    </div>

    <!-- UI Interaction Helper -->
    <script>
        // Sincronização em tempo real entre inputs e preview
        document.getElementById('imageUrl')?.addEventListener('input', function(e) {
            const preview = document.getElementById('char-preview');
            if (preview) preview.src = e.target.value || '/assets/img/placeholders/character.png';
        });

        document.getElementById('role')?.addEventListener('change', function(e) {
            const badge = document.getElementById('preview-role-badge');
            if (badge) {
                badge.innerText = e.target.options[e.target.selectedIndex].text;
                badge.className = e.target.value === 'Main' ? 'oc-badge badge-role-main' : 'oc-badge badge-role-supporting';
            }
        });
    </script>
</body>
</html>