<!DOCTYPE html>
<html lang="pt-AO" data-theme="dark">
<head>
    <%- include('../../partials/head-meta', { title: 'Gestão de Personagens', moduleStyle: 'characters' }) %>
</head>
<body>
    <div id="app-wrapper">
        <!-- Sidebar Navigation -->
        <%- include('../../partials/sidebar', { active: 'characters' }) %>

        <div id="main-content" class="sidebar-transition">
            <!-- Top Navbar -->
            <%- include('../../partials/navbar') %>

            <main class="content-body">
                <!-- Breadcrumbs & Header -->
                <%- include('../../partials/breadcrumbs', { 
                    breadcrumbs: [
                        { name: 'Catálogo', url: '#' },
                        { name: 'Personagens', url: '/characters' }
                    ] 
                }) %>

                <div class="section-header d-flex justify-content-between align-items-center mb-4">
                    <div>
                        <h2 class="text-main mb-1">Base de Personagens</h2>
                        <p class="text-muted small">Gerencie os protagonistas e coadjuvantes que compõem os desafios do Quiz.</p>
                    </div>
                    <button class="btn-oc btn-oc-primary" id="btn-add-character">
                        <i class="bi bi-person-plus-fill me-2"></i> Novo Personagem
                    </button>
                </div>

                <!-- Characters Stats Row -->
                <div class="row g-4 mb-4" data-aos="fade-up">
                    <div class="col-md-4">
                        <div class="oc-card border-start border-4 border-info">
                            <div class="d-flex align-items-center justify-content-between">
                                <div>
                                    <small class="text-dim d-block">Total de Personagens</small>
                                    <span class="fs-4 fw-800 text-main" id="stat-total-chars">0</span>
                                </div>
                                <div class="stat-card-icon text-info bg-info bg-opacity-10">
                                    <i class="bi bi-people"></i>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="oc-card border-start border-4 border-primary">
                            <div class="d-flex align-items-center justify-content-between">
                                <div>
                                    <small class="text-dim d-block">Principais (Main)</small>
                                    <span class="fs-4 fw-800 text-main" id="stat-main-chars">0</span>
                                </div>
                                <div class="stat-card-icon text-primary bg-primary bg-opacity-10">
                                    <i class="bi bi-star-fill"></i>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="oc-card border-start border-4 border-secondary">
                            <div class="d-flex align-items-center justify-content-between">
                                <div>
                                    <small class="text-dim d-block">Animes Cobertos</small>
                                    <span class="fs-4 fw-800 text-main" id="stat-animes-covered">0</span>
                                </div>
                                <div class="stat-card-icon text-secondary bg-secondary bg-opacity-10">
                                    <i class="bi bi-collection-play"></i>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Search & Filters -->
                <div class="oc-card mb-4" data-aos="fade-up">
                    <div class="row g-3">
                        <div class="col-md-8">
                            <div class="auth-input-group mb-0">
                                <i class="bi bi-search"></i>
                                <input type="text" id="character-search" class="form-control" placeholder="Buscar por nome do personagem...">
                            </div>
                        </div>
                        <div class="col-md-4">
                            <button class="btn-oc btn-oc-outline w-100" id="btn-refresh-characters">
                                <i class="bi bi-arrow-clockwise me-2"></i> Actualizar Base
                            </button>
                        </div>
                    </div>
                </div>

                <!-- Characters Table -->
                <div class="oc-card p-0 overflow-hidden" data-aos="fade-up">
                    <div id="char-loader" class="text-center py-5" style="display: none;">
                        <div class="spinner-custom mx-auto"></div>
                        <p class="text-muted mt-2 small">Sincronizando personagens...</p>
                    </div>
                    <div class="oc-table-container">
                        <table class="oc-table mb-0" id="characters-table">
                            <thead>
                                <tr>
                                    <th class="ps-4">Avatar</th>
                                    <th>Nome</th>
                                    <th>Anime Vinculado</th>
                                    <th>Papel</th>
                                    <th class="text-end pe-4">Ações</th>
                                </tr>
                            </thead>
                            <tbody>
                                <!-- Injetado dinamicamente via characters.js -->
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- Pagination -->
                <div class="d-flex justify-content-between align-items-center mt-4" data-aos="fade-up">
                    <div class="text-dim small">
                        Padrão de exibição: 10 personagens por página
                    </div>
                    <div class="pagination-wrapper" id="characters-pagination">
                        <!-- Gerado via JS -->
                    </div>
                </div>
            </main>

            <!-- Modal: Form de Personagem -->
            <div class="modal fade" id="character-modal" tabindex="-1" aria-hidden="true">
                <div class="modal-dialog modal-dialog-centered modal-lg">
                    <div class="modal-content shadow-lg border-secondary">
                        <div class="modal-header border-secondary bg-main">
                            <h5 class="modal-title fw-bold" id="modal-title">Novo Personagem</h5>
                            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                        </div>
                        <form id="character-form">
                            <input type="hidden" id="char-id" name="id">
                            <div class="modal-body p-4">
                                <div class="row g-4">
                                    <div class="col-md-4 text-center border-end border-secondary">
                                        <label class="oc-label mb-3">Imagem de Perfil</label>
                                        <div class="char-upload-preview mb-3">
                                            <img src="/assets/img/placeholders/character.png" id="char-preview" alt="Preview">
                                        </div>
                                        <div class="oc-input-group">
                                            <label class="oc-label small">URL da Imagem</label>
                                            <input type="url" name="imageUrl" id="imageUrl" class="oc-input small" placeholder="https://..." required>
                                        </div>
                                    </div>
                                    <div class="col-md-8">
                                        <div class="row">
                                            <div class="col-md-12">
                                                <div class="oc-input-group">
                                                    <label class="oc-label">Nome Completo</label>
                                                    <input type="text" name="name" id="name" class="oc-input" required placeholder="Ex: Monkey D. Luffy">
                                                </div>
                                            </div>
                                            <div class="col-md-12">
                                                <div class="oc-input-group">
                                                    <label class="oc-label">Anime Vinculado</label>
                                                    <select name="anime_id" id="anime_id" class="oc-input" required>
                                                        <option value="">Selecione o Anime...</option>
                                                        <!-- Populado via loadAnimesList -->
                                                    </select>
                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <div class="oc-input-group">
                                                    <label class="oc-label">Papel (Role)</label>
                                                    <select name="role" id="role" class="oc-input">
                                                        <option value="Main">Principal (Main)</option>
                                                        <option value="Supporting">Secundário (Supporting)</option>
                                                        <option value="Antagonist">Antagonista</option>
                                                    </select>
                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <div class="oc-input-group">
                                                    <label class="oc-label">MAL ID (Opcional)</label>
                                                    <input type="number" name="mal_id" id="mal_id" class="oc-input" placeholder="ID MyAnimeList">
                                                </div>
                                            </div>
                                        </div>
                                        <div class="oc-input-group mb-0">
                                            <label class="oc-label">Sobre / Biografia</label>
                                            <textarea name="about" id="about" class="oc-input" rows="4" placeholder="Breve história do personagem..."></textarea>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="modal-footer border-secondary bg-main p-3">
                                <button type="button" class="btn-oc btn-oc-outline" data-bs-dismiss="modal">Descartar</button>
                                <button type="submit" class="btn-oc btn-oc-primary" id="btn-save-character">
                                    <i class="bi bi-check-lg me-2"></i> Salvar Personagem
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

            <!-- Global Footer & Scripts -->
            <%- include('../../partials/footer', { moduleScript: 'characters/characters' }) %>
        </div>
    </div>
</body>
</html>