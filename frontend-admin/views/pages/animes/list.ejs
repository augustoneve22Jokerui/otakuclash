<!DOCTYPE html>
<html lang="pt-AO" data-theme="dark">
<head>
    <%- include('../../partials/head-meta', { title: 'Catálogo de Animes', moduleStyle: 'animes' }) %>
</head>
<body>
    <div id="app-wrapper">
        <!-- Sidebar Navigation -->
        <%- include('../../partials/sidebar', { active: 'animes' }) %>

        <div id="main-content" class="sidebar-transition">
            <!-- Top Navbar -->
            <%- include('../../partials/navbar') %>

            <main class="content-body">
                <!-- Breadcrumbs & Header -->
                <%- include('../../partials/breadcrumbs', { 
                    breadcrumbs: [
                        { name: 'Catálogo', url: '#' },
                        { name: 'Animes', url: '/animes' }
                    ] 
                }) %>

                <div class="section-header d-flex justify-content-between align-items-center mb-4">
                    <div>
                        <h2 class="text-main mb-1">Catálogo de Animes</h2>
                        <p class="text-muted small">Gerencie o acervo de obras, metadados e sincronização com a API Jikan.</p>
                    </div>
                    <div class="d-flex gap-2">
                        <button class="btn-oc btn-oc-outline" id="btn-sync-mal">
                            <i class="bi bi-cloud-download me-2"></i> Importar do MyAnimeList
                        </button>
                        <a href="/animes/new" class="btn-oc btn-oc-primary">
                            <i class="bi bi-plus-lg"></i> Adicionar Manualmente
                        </a>
                    </div>
                </div>

                <!-- Stats Overview -->
                <div class="row g-4 mb-4" data-aos="fade-up">
                    <div class="col-md-3">
                        <div class="oc-card catalog-stat-card">
                            <small class="text-dim d-block">Obras Registadas</small>
                            <div class="d-flex align-items-center justify-content-between mt-1">
                                <span class="fs-4 fw-800 text-main" id="total-animes-count">0</span>
                                <i class="bi bi-collection-play text-primary"></i>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="oc-card catalog-stat-card border-secondary">
                            <small class="text-dim d-block">Média de Score</small>
                            <div class="d-flex align-items-center justify-content-between mt-1">
                                <span class="fs-4 fw-800 text-main">8.42</span>
                                <i class="bi bi-star-fill text-warning"></i>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="sync-status-indicator h-100 mb-0">
                            <div class="sync-pulse"></div>
                            <div>
                                <strong class="text-main d-block small">Sincronização Automatizada</strong>
                                <span class="text-muted" style="font-size: 11px;">O Cron Job actualiza o catálogo diariamente às 03:00 AM (Luanda).</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Advanced Filters -->
                <div class="oc-card mb-4" data-aos="fade-up">
                    <div class="row g-3">
                        <div class="col-lg-4 col-md-6">
                            <div class="auth-input-group mb-0">
                                <i class="bi bi-search"></i>
                                <input type="text" id="anime-search" class="form-control" placeholder="Buscar por título ou MAL ID...">
                            </div>
                        </div>
                        <div class="col-lg-2 col-md-3">
                            <select id="filter-genre" class="oc-input border-0 bg-dark">
                                <option value="">Todos os Géneros</option>
                                <!-- Injetado via JS -->
                            </select>
                        </div>
                        <div class="col-lg-2 col-md-3">
                            <select id="filter-type" class="oc-input border-0 bg-dark">
                                <option value="">Tipo (Todos)</option>
                                <option value="TV">TV (Série)</option>
                                <option value="Movie">Filme</option>
                                <option value="OVA">OVA</option>
                                <option value="Special">Especial</option>
                            </select>
                        </div>
                        <div class="col-lg-2 col-md-6">
                            <select id="filter-order" class="oc-input border-0 bg-dark">
                                <option value="score">Ordenar por Score</option>
                                <option value="title">Ordem Alfabética</option>
                                <option value="year">Ano de Lançamento</option>
                                <option value="created_at">Data de Adição</option>
                            </select>
                        </div>
                        <div class="col-lg-2 col-md-6">
                            <button class="btn-oc btn-oc-outline w-100" id="btn-refresh-list">
                                <i class="bi bi-filter"></i> Aplicar
                            </button>
                        </div>
                    </div>
                </div>

                <!-- Anime List Table -->
                <div class="oc-card p-0 overflow-hidden" data-aos="fade-up">
                    <div id="anime-table-loader" class="text-center py-5" style="display: none;">
                        <div class="spinner-custom mx-auto"></div>
                        <p class="text-muted mt-2 small">Carregando catálogo...</p>
                    </div>
                    <div class="oc-table-container">
                        <table class="oc-table mb-0" id="animes-table">
                            <thead>
                                <tr>
                                    <th class="ps-4">Capa</th>
                                    <th>Título e Géneros</th>
                                    <th>Formato</th>
                                    <th>Avaliação</th>
                                    <th>Última Sync</th>
                                    <th class="text-end pe-4">Ações</th>
                                </tr>
                            </thead>
                            <tbody>
                                <!-- Injetado dinamicamente via animes-list.js -->
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- Pagination -->
                <div class="d-flex justify-content-between align-items-center mt-4" data-aos="fade-up">
                    <div class="text-dim small">
                        A exibir <span class="text-main fw-bold" id="pagination-info">0</span> animes por página
                    </div>
                    <div class="pagination-wrapper" id="pagination-container">
                        <!-- Botões de página injetados via JS -->
                    </div>
                </div>
            </main>

            <!-- Global Footer -->
            <%- include('../../partials/footer', { moduleScript: 'animes/animes-list' }) %>
        </div>
    </div>
</body>
</html>