<!DOCTYPE html>
<html lang="pt-AO" data-theme="dark">
<head>
    <%- include('../../partials/head-meta', { title: (typeof animeId !== 'undefined' ? 'Editar Anime' : 'Novo Anime'), moduleStyle: 'animes' }) %>
</head>
<body>
    <div id="app-wrapper">
        <!-- Sidebar Navigation -->
        <%- include('../../partials/sidebar', { active: 'animes' }) %>

        <div id="main-content" class="sidebar-transition">
            <!-- Top Navbar -->
            <%- include('../../partials/navbar') %>

            <main class="content-body">
                <!-- Breadcrumbs & Header -->
                <%- include('../../partials/breadcrumbs', { 
                    breadcrumbs: [
                        { name: 'Catálogo', url: '#' },
                        { name: 'Animes', url: '/animes' },
                        { name: (typeof animeId !== 'undefined' ? 'Editar Obra' : 'Nova Obra'), url: '#' }
                    ] 
                }) %>

                <div class="section-header d-flex justify-content-between align-items-center mb-4">
                    <div>
                        <h2 class="text-main mb-1"><%= (typeof animeId !== 'undefined' ? 'Editar Anime' : 'Adicionar Anime') %></h2>
                        <p class="text-muted small">Preencha os metadados da obra ou sincronize via MAL ID para preenchimento automático.</p>
                    </div>
                    <button type="button" class="btn-oc btn-oc-outline" id="btn-cancel">
                        <i class="bi bi-x-lg"></i> Cancelar
                    </button>
                </div>

                <div class="row g-4">
                    <!-- Column: Main Form -->
                    <div class="col-xl-8 col-lg-7">
                        <div class="oc-card" data-aos="fade-up">
                            <form id="anime-form">
                                <input type="hidden" id="anime-id" value="<%= typeof animeId !== 'undefined' ? animeId : '' %>">
                                
                                <div class="row">
                                    <div class="col-md-8">
                                        <div class="oc-input-group">
                                            <label class="oc-label" for="title">Título Original (JP/Romaji)</label>
                                            <input type="text" id="title" name="title" class="oc-input" required data-validate placeholder="Ex: Shingeki no Kyojin">
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="oc-input-group">
                                            <label class="oc-label" for="mal_id">MAL ID (MyAnimeList)</label>
                                            <input type="number" id="mal_id" name="mal_id" class="oc-input" required placeholder="Ex: 16498">
                                        </div>
                                    </div>
                                    <div class="col-12">
                                        <div class="oc-input-group">
                                            <label class="oc-label" for="titleEnglish">Título em Inglês / Internacional</label>
                                            <input type="text" id="titleEnglish" name="titleEnglish" class="oc-input" placeholder="Ex: Attack on Titan">
                                        </div>
                                    </div>
                                </div>

                                <div class="oc-input-group">
                                    <label class="oc-label" for="synopsis">Sinopse da Obra</label>
                                    <textarea id="synopsis" name="synopsis" class="oc-input synopsis-textarea" placeholder="Breve resumo da história..."></textarea>
                                </div>

                                <div class="row">
                                    <div class="col-md-4">
                                        <div class="oc-input-group">
                                            <label class="oc-label" for="type">Formato</label>
                                            <select id="type" name="type" class="oc-input">
                                                <option value="TV">TV (Série)</option>
                                                <option value="Movie">Filme</option>
                                                <option value="OVA">OVA</option>
                                                <option value="ONA">ONA</option>
                                                <option value="Special">Especial</option>
                                                <option value="Music">Music Video</option>
                                            </select>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="oc-input-group">
                                            <label class="oc-label" for="status">Status</label>
                                            <select id="status" name="status" class="oc-input">
                                                <option value="Finished Airing">Finalizado</option>
                                                <option value="Currently Airing">Em Lançamento</option>
                                                <option value="Not yet aired">Ainda não lançado</option>
                                            </select>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="oc-input-group">
                                            <label class="oc-label" for="episodes">Nº Episódios</label>
                                            <input type="number" id="episodes" name="episodes" class="oc-input" value="1">
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-4">
                                        <div class="oc-input-group">
                                            <label class="oc-label" for="score">Score Base (Global)</label>
                                            <div class="input-rating-wrapper">
                                                <input type="number" step="0.01" id="score" name="score" class="oc-input" placeholder="0.00">
                                                <i class="bi bi-star-fill text-warning"></i>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="oc-input-group">
                                            <label class="oc-label" for="year">Ano de Produção</label>
                                            <input type="number" id="year" name="year" class="oc-input" placeholder="Ex: 2024">
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="oc-input-group">
                                            <label class="oc-label" for="genres">Géneros (Separados por vírgula)</label>
                                            <input type="text" id="genres" name="genres" class="oc-input" placeholder="Ação, Aventura...">
                                        </div>
                                    </div>
                                </div>

                                <div class="oc-input-group">
                                    <label class="oc-label" for="imageUrl">URL da Imagem de Capa (CDN)</label>
                                    <input type="url" id="imageUrl" name="imageUrl" class="oc-input" required placeholder="https://cdn.myanimelist.net/...">
                                </div>

                                <div class="mt-4 d-flex gap-2">
                                    <button type="submit" class="btn-oc btn-oc-primary flex-grow-1" id="btn-save-anime">
                                        <i class="bi bi-cloud-check me-2"></i> Salvar no Catálogo
                                    </button>
                                </div>
                            </form>
                        </div>
                    </div>

                    <!-- Column: Preview & Metadata -->
                    <div class="col-xl-4 col-lg-5">
                        <!-- Cover Preview Card -->
                        <div class="oc-card mb-4 text-center" data-aos="fade-left">
                            <h6 class="text-main fw-bold mb-3">Pré-visualização da Capa</h6>
                            <img src="/assets/img/placeholders/anime-cover.png" id="cover-preview" class="anime-cover-full shadow-lg" alt="Anime Preview">
                            <div class="mt-3">
                                <span id="preview-type-badge" class="oc-badge badge-info">FORMATO</span>
                                <span id="preview-score-badge" class="score-badge ms-2">0.00</span>
                            </div>
                        </div>

                        <!-- Linked Content Info -->
                        <div class="oc-card mb-4" data-aos="fade-left" data-aos-delay="100">
                            <h6 class="text-main fw-bold mb-3"><i class="bi bi-link-45deg me-2 text-primary"></i>Conteúdo Vinculado</h6>
                            <div class="list-group list-group-flush bg-transparent">
                                <div class="list-group-item bg-transparent border-secondary px-0 d-flex justify-content-between">
                                    <span class="text-dim small">Personagens</span>
                                    <span class="text-main fw-bold" id="count-chars">0</span>
                                </div>
                                <div class="list-group-item bg-transparent border-secondary px-0 d-flex justify-content-between">
                                    <span class="text-dim small">Questões de Quiz</span>
                                    <span class="text-main fw-bold" id="count-questions">0</span>
                                </div>
                                <div class="list-group-item bg-transparent border-0 px-0 d-flex justify-content-between">
                                    <span class="text-dim small">Participação em Torneios</span>
                                    <span class="text-main fw-bold" id="count-tournaments">0</span>
                                </div>
                            </div>
                        </div>

                        <!-- Technical Sync Info -->
                        <div class="oc-card bg-dark border-secondary border-opacity-50" data-aos="fade-left" data-aos-delay="200">
                            <h6 class="text-dim fw-bold small mb-3 uppercase">Integridade de Dados</h6>
                            <div class="small text-muted mb-2">
                                <i class="bi bi-clock-history me-2"></i> Adicionado em: <span id="created-at-display" class="text-main">--/--/----</span>
                            </div>
                            <div class="small text-muted">
                                <i class="bi bi-arrow-repeat me-2"></i> Última Sync: <span id="updated-at-display" class="text-main">--/--/----</span>
                            </div>
                        </div>
                    </div>
                </div>
            </main>

            <!-- Global Footer & Scripts -->
            <%- include('../../partials/footer', { moduleScript: 'animes/animes-form' }) %>
        </div>
    </div>

    <!-- Script for Loader Overlay if needed -->
    <div id="form-loader" class="position-fixed top-0 start-0 w-100 h-100 bg-dark bg-opacity-75 d-flex align-items-center justify-content-center" style="display: none; z-index: 2000;">
        <div class="text-center">
            <div class="spinner-custom mx-auto mb-3"></div>
            <p class="text-white fw-bold">Sincronizando com Jikan API...</p>
        </div>
    </div>
</body>
</html>