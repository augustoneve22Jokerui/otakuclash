<!DOCTYPE html>
<html lang="pt-AO" data-theme="dark">
<head>
    <%- include('../../partials/head-meta', { title: 'Registos de Auditoria', moduleStyle: 'audit-logs' }) %>
</head>
<body>
    <div id="app-wrapper">
        <!-- Sidebar Navigation -->
        <%- include('../../partials/sidebar', { active: 'audit-logs' }) %>

        <div id="main-content" class="sidebar-transition">
            <!-- Top Navbar -->
            <%- include('../../partials/navbar') %>

            <main class="content-body">
                <!-- Breadcrumbs & Header -->
                <%- include('../../partials/breadcrumbs', { 
                    breadcrumbs: [
                        { name: 'Administração', url: '#' },
                        { name: 'Logs de Auditoria', url: '/audit-logs' }
                    ] 
                }) %>

                <div class="section-header d-flex justify-content-between align-items-center mb-4">
                    <div>
                        <h2 class="text-main mb-1">Rastreabilidade do Sistema</h2>
                        <p class="text-muted small">Monitoramento em tempo real de todas as acções administrativas e alterações críticas.</p>
                    </div>
                    <div class="d-flex gap-2">
                        <button class="btn-oc btn-oc-outline" id="btn-export-logs">
                            <i class="bi bi-download me-2"></i> Exportar CSV
                        </button>
                        <button class="btn-oc btn-oc-primary" id="btn-refresh-logs">
                            <i class="bi bi-arrow-clockwise"></i> Actualizar
                        </button>
                    </div>
                </div>

                <!-- Advanced Filters & Compliance -->
                <div class="oc-card mb-4" data-aos="fade-up">
                    <div class="row g-3">
                        <div class="col-lg-3 col-md-6">
                            <label class="oc-label">Filtrar por Acção</label>
                            <select id="filter-action" class="oc-input border-0 bg-dark">
                                <option value="">Todas as Acções</option>
                                <option value="CHANGE_USER_ROLE">Alteração de Cargo</option>
                                <option value="SUSPEND_USER">Suspensão de Conta</option>
                                <option value="DELETE_QUESTION">Remoção de Questão</option>
                                <option value="ADJUST_BALANCE">Ajuste de Saldo</option>
                                <option value="SYNC_CATALOG">Sincronização de Catálogo</option>
                                <option value="LOGIN_ADMIN">Login Administrativo</option>
                            </select>
                        </div>
                        <div class="col-lg-3 col-md-6">
                            <label class="oc-label">Tipo de Recurso</label>
                            <select id="filter-resource" class="oc-input border-0 bg-dark">
                                <option value="">Todos os Recursos</option>
                                <option value="USER">Usuários</option>
                                <option value="WALLET">Financeiro</option>
                                <option value="QUIZ">Quiz / Questões</option>
                                <option value="SYSTEM">Configurações</option>
                                <option value="GUILD">Guildas</option>
                            </select>
                        </div>
                        <div class="col-lg-4 col-md-8">
                            <label class="oc-label">Período de Retenção</label>
                            <div class="retention-notice d-flex align-items-center h-100 mt-md-n2">
                                <i class="bi bi-shield-check me-2"></i>
                                <span>Logs armazenados por 90 dias conforme política de compliance.</span>
                            </div>
                        </div>
                        <div class="col-lg-2 col-md-4 d-flex align-items-end">
                            <div class="text-end w-100">
                                <span class="text-dim small">Total de Registos:</span>
                                <div class="fw-bold text-main fs-5" id="total-logs-count">0</div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Audit Table -->
                <div class="oc-card p-0 overflow-hidden" data-aos="fade-up">
                    <div id="audit-loader" class="text-center py-5" style="display: none;">
                        <div class="spinner-custom mx-auto"></div>
                        <p class="text-muted mt-2 small">Consultando histórico de segurança...</p>
                    </div>
                    
                    <div class="oc-table-container">
                        <table class="oc-table mb-0" id="audit-table">
                            <thead>
                                <tr>
                                    <th class="ps-4">Data e Hora</th>
                                    <th>Administrador / IP</th>
                                    <th>Evento</th>
                                    <th>Recurso Afectado</th>
                                    <th class="text-end pe-4">Integridada</th>
                                </tr>
                            </thead>
                            <tbody>
                                <!-- Injetado dinamicamente via audit-logs.js -->
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- Pagination Footer -->
                <div class="d-flex justify-content-between align-items-center mt-4" data-aos="fade-up">
                    <div class="text-dim small">
                        Mostrando registos cronológicos reversos
                    </div>
                    <div class="pagination-wrapper" id="audit-pagination">
                        <!-- Botões de página injetados via JS -->
                    </div>
                </div>
            </main>

            <!-- Global Footer & Scripts -->
            <%- include('../../partials/footer', { moduleScript: 'audit-logs/audit-logs' }) %>
        </div>
    </div>

    <!-- Modal: Detalhes Técnicos do Log (Diff Viewer) -->
    <div class="modal fade audit-detail-modal" id="audit-modal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content shadow-lg border-secondary">
                <div class="modal-header border-secondary bg-main">
                    <h5 class="modal-title fw-bold">
                        <i class="bi bi-shield-text me-2 text-primary"></i> 
                        Inspecção Técnica de Evento
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body p-4">
                    <div class="audit-metadata-grid mb-4">
                        <div class="resource-badge">
                            <i class="bi bi-key"></i> <span id="modal-log-id">---</span>
                        </div>
                        <div class="resource-badge">
                            <i class="bi bi-laptop"></i> <span id="modal-log-ip">0.0.0.0</span>
                        </div>
                        <div class="resource-badge">
                            <i class="bi bi-clock"></i> <span id="modal-log-date">--/--/----</span>
                        </div>
                    </div>

                    <h6 class="text-main fw-bold mb-3">Comparação de Estado (JSON Diff)</h6>
                    <div class="diff-container">
                        <div class="diff-box">
                            <span class="diff-label">Estado Anterior</span>
                            <pre id="modal-old-values" class="json-pretty"></pre>
                        </div>
                        <div class="diff-box">
                            <span class="diff-label">Novo Estado</span>
                            <pre id="modal-new-values" class="json-pretty"></pre>
                        </div>
                    </div>

                    <div class="alert alert-info bg-dark border-secondary mt-4 mb-0">
                        <div class="d-flex align-items-start gap-2">
                            <i class="bi bi-info-circle-fill mt-1"></i>
                            <div class="small">
                                <strong class="d-block">Assinatura Digital de Integridade</strong>
                                <span class="text-muted" id="modal-log-hash">Verificando hash criptográfico da transação...</span>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-secondary bg-main">
                    <button type="button" class="btn-oc btn-oc-outline w-100" data-bs-dismiss="modal">Fechar Inspecção</button>
                </div>
            </div>
        </div>
    </div>
</body>
</html>