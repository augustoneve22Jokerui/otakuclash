<!DOCTYPE html>
<html lang="pt-AO" data-theme="dark">
<head>
    <%- include('../../partials/head-meta', { title: 'Gestão de Torneios', moduleStyle: 'tournaments' }) %>
</head>
<body>
    <div id="app-wrapper">
        <!-- Sidebar Navigation -->
        <%- include('../../partials/sidebar', { active: 'tournaments' }) %>

        <div id="main-content" class="sidebar-transition">
            <!-- Top Navbar -->
            <%- include('../../partials/navbar') %>

            <main class="content-body">
                <!-- Breadcrumbs & Header -->
                <%- include('../../partials/breadcrumbs', { 
                    breadcrumbs: [
                        { name: 'Arena & Competição', url: '#' },
                        { name: 'Torneios Oficiais', url: '/tournaments' }
                    ] 
                }) %>

                <div class="section-header d-flex justify-content-between align-items-center mb-4">
                    <div>
                        <h2 class="text-main mb-1">Competições Oficiais</h2>
                        <p class="text-muted small">Organize grandes eventos sazonais, controle premiações em AKZ e gerencie chaves de competidores.</p>
                    </div>
                    <button class="btn-oc btn-oc-primary" id="btn-create-tournament">
                        <i class="bi bi-trophy-fill me-2"></i> Agendar Novo Torneio
                    </button>
                </div>

                <!-- Tournament Overview Stats -->
                <div class="row g-4 mb-5" data-aos="fade-up">
                    <div class="col-md-3">
                        <div class="oc-card stat-card hover-lift secondary">
                            <div class="stat-card-icon"><i class="bi bi-calendar-check"></i></div>
                            <div class="stat-card-value">12</div>
                            <div class="stat-card-label">Torneios Realizados</div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="oc-card stat-card hover-lift primary">
                            <div class="stat-card-icon"><i class="bi bi-award"></i></div>
                            <div class="stat-card-value">2.4k</div>
                            <div class="stat-card-label">Total de Participantes</div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="oc-card h-100 bg-dark border-secondary border-opacity-50 p-4">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <span class="text-dim small fw-bold uppercase">Volume Total de Prêmios (AKZ)</span>
                                <span class="text-success small fw-bold">+18.5% este mês</span>
                            </div>
                            <div class="d-flex align-items-baseline gap-2">
                                <span class="fs-2 fw-800 text-main">450.000,00</span>
                                <span class="text-muted">AKZ distribuídos</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Filters and Search Bar -->
                <div class="oc-card mb-4" data-aos="fade-up">
                    <div class="row g-3">
                        <div class="col-xl-3 col-md-6">
                            <label class="oc-label">Estado da Competição</label>
                            <select id="filter-tournament-status" class="oc-input border-0 bg-dark">
                                <option value="">Todos os Estados</option>
                                <option value="REGISTRATION">Inscrições Abertas</option>
                                <option value="IN_PROGRESS">Em Andamento</option>
                                <option value="FINISHED">Finalizados</option>
                                <option value="CANCELLED">Cancelados</option>
                            </select>
                        </div>
                        <div class="col-xl-4 col-md-6">
                            <label class="oc-label">Filtrar por Anime</label>
                            <select id="filter-tournament-anime" class="oc-input border-0 bg-dark">
                                <option value="">Qualquer Tema</option>
                                <!-- Injetado via loadAnimesList em tournaments-manage.js -->
                            </select>
                        </div>
                        <div class="col-xl-5 col-md-12 d-flex align-items-end">
                            <button class="btn-oc btn-oc-outline w-100" id="btn-refresh-tournaments">
                                <i class="bi bi-arrow-clockwise me-2"></i> Sincronizar Calendário de Eventos
                            </button>
                        </div>
                    </div>
                </div>

                <!-- Tournament Grid View -->
                <div id="tournaments-loader" class="text-center py-5" style="display: none;">
                    <div class="spinner-custom mx-auto mb-3"></div>
                    <p class="text-muted small">Consultando servidores de competição...</p>
                </div>

                <div class="row tournament-grid" id="tournaments-grid">
                    <!-- Cards dynamically injected via tournaments-manage.js -->
                </div>

                <!-- Pagination -->
                <div class="d-flex justify-content-between align-items-center mt-5" data-aos="fade-up">
                    <div class="text-dim small">
                        Padrão de exibição: Competições activas primeiro
                    </div>
                    <div class="pagination-wrapper" id="tournaments-pagination">
                        <!-- Botões de página injetados via JS -->
                    </div>
                </div>
            </main>

            <!-- Modal: Cadastro/Edição de Torneio -->
            <div class="modal fade" id="tournament-modal" tabindex="-1" aria-hidden="true">
                <div class="modal-dialog modal-dialog-centered modal-lg">
                    <div class="modal-content shadow-lg border-secondary">
                        <div class="modal-header border-secondary bg-main px-4">
                            <h5 class="modal-title fw-bold" id="modal-tournament-title">Configurar Nova Competição</h5>
                            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                        </div>
                        <form id="tournament-form">
                            <input type="hidden" id="tournament-id" name="id">
                            <div class="modal-body p-4 bg-card">
                                <div class="row g-4">
                                    <div class="col-md-8">
                                        <div class="oc-input-group">
                                            <label class="oc-label">Nome do Torneio</label>
                                            <input type="text" name="name" class="oc-input" required placeholder="Ex: Grand Slam Angola 2026">
                                        </div>
                                        <div class="oc-input-group">
                                            <label class="oc-label">Descrição / Regras Específicas</label>
                                            <textarea name="description" class="oc-input" rows="3" placeholder="Detalhes sobre o formato do torneio..."></textarea>
                                        </div>
                                        <div class="row">
                                            <div class="col-6">
                                                <div class="oc-input-group">
                                                    <label class="oc-label">Anime Base</label>
                                                    <select name="anime_id" id="anime_id" class="oc-input" required>
                                                        <option value="">Tema do torneio...</option>
                                                    </select>
                                                </div>
                                            </div>
                                            <div class="col-6">
                                                <div class="oc-input-group">
                                                    <label class="oc-label">Nível Mínimo</label>
                                                    <input type="number" name="min_level" class="oc-input" value="1" min="1">
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <label class="oc-label mb-3">Banner do Evento</label>
                                        <div class="banner-upload-area" onclick="document.getElementById('banner-input').click()">
                                            <i class="bi bi-image-fill fs-2 mb-2 text-dim"></i>
                                            <span class="small text-muted">Click para upload</span>
                                            <img id="banner-preview" class="d-none w-100 h-100 object-fit-cover rounded-md position-absolute top-0 start-0">
                                        </div>
                                        <input type="file" id="banner-input" hidden accept="image/*">
                                        <input type="hidden" name="banner_url" id="banner_url">
                                        
                                        <div class="mt-4">
                                            <div class="oc-input-group">
                                                <label class="oc-label">Máx. Competidores</label>
                                                <input type="number" name="max_participants" class="oc-input" required value="64">
                                            </div>
                                        </div>
                                    </div>

                                    <div class="col-12"><hr class="border-secondary my-1"></div>

                                    <div class="col-md-6">
                                        <h6 class="text-warning fw-bold mb-3"><i class="bi bi-cash-coin me-2"></i>Financeiro</h6>
                                        <div class="oc-input-group">
                                            <label class="oc-label">Taxa de Inscrição (AKZ)</label>
                                            <input type="number" name="entry_fee" class="oc-input" required value="0">
                                        </div>
                                        <div class="oc-input-group mb-0">
                                            <label class="oc-label">Prêmio Total (Prize Pool)</label>
                                            <input type="number" name="prize_pool" class="oc-input" required value="0">
                                        </div>
                                    </div>

                                    <div class="col-md-6">
                                        <h6 class="text-primary fw-bold mb-3"><i class="bi bi-clock-history me-2"></i>Cronograma</h6>
                                        <div class="oc-input-group">
                                            <label class="oc-label">Abertura de Inscrições</label>
                                            <input type="datetime-local" name="registration_opens_at" class="oc-input" required>
                                        </div>
                                        <div class="oc-input-group mb-0">
                                            <label class="oc-label">Início da Competição</label>
                                            <input type="datetime-local" name="start_at" class="oc-input" required>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="modal-footer border-secondary bg-main p-3">
                                <button type="button" class="btn-oc btn-oc-outline" data-bs-dismiss="modal">Descartar</button>
                                <button type="submit" class="btn-oc btn-oc-primary" id="btn-save-tournament">
                                    <i class="bi bi-cloud-check me-2"></i> Publicar Torneio
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

            <!-- Global Footer & Scripts -->
            <%- include('../../partials/footer', { moduleScript: 'tournaments/tournaments-manage' }) %>
        </div>
    </div>
</body>
</html>