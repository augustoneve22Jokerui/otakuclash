<!DOCTYPE html>
<html lang="pt-AO" data-theme="dark">
<head>
    <%- include('../../partials/head-meta', { title: 'Perfis de Jogadores', moduleStyle: 'profiles' }) %>
</head>
<body>
    <div id="app-wrapper">
        <!-- Sidebar Navigation -->
        <%- include('../../partials/sidebar', { active: 'profiles' }) %>

        <div id="main-content" class="sidebar-transition">
            <!-- Top Navbar -->
            <%- include('../../partials/navbar') %>

            <main class="content-body">
                <!-- Breadcrumbs & Header -->
                <%- include('../../partials/breadcrumbs', { 
                    breadcrumbs: [
                        { name: 'Social & Engajamento', url: '#' },
                        { name: 'Perfis de Jogadores', url: '/profiles' }
                    ] 
                }) %>

                <div class="section-header d-flex justify-content-between align-items-center mb-4">
                    <div>
                        <h2 class="text-main mb-1">Directório de Identidades</h2>
                        <p class="text-muted small">Visualize o progresso social, conquistas e estatísticas competitivas dos jogadores.</p>
                    </div>
                    <div class="d-flex gap-2">
                        <button class="btn-oc btn-oc-outline" id="btn-refresh-profiles">
                            <i class="bi bi-arrow-clockwise me-2"></i> Actualizar
                        </button>
                    </div>
                </div>

                <div class="row g-4">
                    <!-- Left Column: Filters -->
                    <div class="col-xl-3 col-lg-4">
                        <div class="profile-filters-sidebar animate-right">
                            <div class="oc-card">
                                <h6 class="text-main fw-bold mb-4">Filtros de Descoberta</h6>
                                
                                <div class="oc-input-group">
                                    <label class="oc-label">Procurar Nickname</label>
                                    <div class="input-group bg-dark rounded-sm overflow-hidden border border-secondary border-opacity-25">
                                        <span class="input-group-text bg-transparent border-0 text-dim"><i class="bi bi-search"></i></span>
                                        <input type="text" id="profile-search" class="form-control bg-transparent border-0 text-white small" placeholder="Ex: Uzumaki_Angola">
                                    </div>
                                </div>

                                <div class="oc-input-group">
                                    <label class="oc-label">Faixa de Nível</label>
                                    <select id="filter-level-range" class="oc-input border-0 bg-dark">
                                        <option value="">Todos os Níveis</option>
                                        <option value="1-10">Iniciantes (1-10)</option>
                                        <option value="11-30">Veteranos (11-30)</option>
                                        <option value="31-50">Elite (31-50)</option>
                                        <option value="51+">Lendas (50+)</option>
                                    </select>
                                </div>

                                <div class="oc-input-group">
                                    <label class="oc-label">Estado de Presença</label>
                                    <select id="filter-online-status" class="oc-input border-0 bg-dark">
                                        <option value="">Todos os Estados</option>
                                        <option value="online">Online agora</option>
                                        <option value="offline">Offline</option>
                                    </select>
                                </div>

                                <div class="oc-input-group mb-0">
                                    <label class="oc-label">Vínculo a Clã</label>
                                    <div class="form-check form-switch mt-2">
                                        <input class="form-check-input" type="checkbox" id="filter-has-guild">
                                        <label class="form-check-label text-muted small" for="filter-has-guild">Apenas membros de clãs</label>
                                    </div>
                                </div>

                                <hr class="border-secondary my-4">

                                <button class="btn-oc btn-oc-primary w-100 py-2" id="btn-apply-profile-filters">
                                    <i class="bi bi-funnel-fill me-2"></i> Aplicar Filtros
                                </button>
                            </div>

                            <!-- System Insight Widget -->
                            <div class="oc-card mt-4 bg-dark border-secondary border-opacity-50">
                                <h6 class="text-dim fw-bold small mb-2 uppercase">População de Luanda</h6>
                                <p class="text-muted" style="font-size: 11px; line-height: 1.4;">
                                    A plataforma regista um crescimento de <span class="text-success fw-bold">12.5%</span> em novos perfis esta semana. A maioria dos jogadores activos concentra-se na faixa de nível 15-25.
                                </p>
                            </div>
                        </div>
                    </div>

                    <!-- Right Column: Profiles Grid -->
                    <div class="col-xl-9 col-lg-8">
                        <!-- Loading State -->
                        <div id="profiles-loader" class="text-center py-5">
                            <div class="spinner-custom mx-auto mb-3"></div>
                            <p class="text-muted small">Mapeando a rede social Otaku...</p>
                        </div>

                        <!-- Dynamic Grid Container -->
                        <div class="profiles-grid" id="profiles-grid">
                            <!-- Populated via profiles.js -->
                        </div>

                        <!-- Empty State (Hidden by default) -->
                        <div id="profiles-empty-state" class="text-center py-5 d-none animate-up">
                            <i class="bi bi-person-x text-dim display-1 mb-3"></i>
                            <h4 class="text-main fw-bold">Nenhuma identidade encontrada</h4>
                            <p class="text-muted">Ajuste os filtros de busca para encontrar outros jogadores.</p>
                            <button class="btn-oc btn-oc-outline btn-sm mt-2" onclick="Profiles.resetFilters()">Limpar Filtros</button>
                        </div>

                        <!-- Pagination Navigation -->
                        <div class="d-flex justify-content-between align-items-center mt-5" data-aos="fade-up">
                            <div class="text-dim small">
                                Total de <span class="text-main fw-bold" id="total-profiles-count">0</span> identidades registadas
                            </div>
                            <div class="pagination-wrapper" id="profiles-pagination">
                                <!-- Botões de página injetados via JS -->
                            </div>
                        </div>
                    </div>
                </div>
            </main>

            <!-- Global Footer & Scripts -->
            <%- include('../../partials/footer', { moduleScript: 'profiles/profiles' }) %>
        </div>
    </div>

    <!-- Logic for AOS refresh on dynamic content -->
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const grid = document.getElementById('profiles-grid');
            const observer = new MutationObserver(() => {
                if (typeof AOS !== 'undefined') AOS.refresh();
            });
            observer.observe(grid, { childList: true });
        });
    </script>
</body>
</html>