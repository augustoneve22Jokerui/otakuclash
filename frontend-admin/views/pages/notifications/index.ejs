<!DOCTYPE html>
<html lang="pt-AO" data-theme="dark">
<head>
    <%- include('../../partials/head-meta', { title: 'Central de Alertas', moduleStyle: 'notifications' }) %>
</head>
<body>
    <div id="app-wrapper">
        <!-- Sidebar Navigation -->
        <%- include('../../partials/sidebar', { active: 'notifications' }) %>

        <div id="main-content" class="sidebar-transition">
            <!-- Top Navbar -->
            <%- include('../../partials/navbar') %>

            <main class="content-body">
                <!-- Breadcrumbs & Header -->
                <%- include('../../partials/breadcrumbs', { 
                    breadcrumbs: [
                        { name: 'Social & Engajamento', url: '#' },
                        { name: 'Notificações', url: '/notifications' }
                    ] 
                }) %>

                <div class="section-header d-flex justify-content-between align-items-center mb-4">
                    <div>
                        <h2 class="text-main mb-1">Central de Comunicação</h2>
                        <p class="text-muted small">Gerencie alertas de sistema, mensagens directas aos usuários e disparos de broadcast global.</p>
                    </div>
                    <div class="d-flex gap-2">
                        <button class="btn-oc btn-oc-outline" id="btn-mark-all-read">
                            <i class="bi bi-check2-all me-2"></i> Marcar Todas como Lidas
                        </button>
                        <button class="btn-oc btn-oc-primary" id="btn-new-notification">
                            <i class="bi bi-megaphone-fill me-2"></i> Novo Broadcast
                        </button>
                    </div>
                </div>

                <!-- Notification Metrics -->
                <div class="row g-4 mb-4" data-aos="fade-up">
                    <div class="col-md-4">
                        <div class="oc-card stat-card hover-lift">
                            <div class="stat-card-icon primary"><i class="bi bi-bell-fill"></i></div>
                            <div class="stat-card-value notification-badge">0</div>
                            <div class="stat-card-label">Alertas Não Lidos</div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="oc-card stat-card hover-lift secondary">
                            <div class="stat-card-icon"><i class="bi bi-broadcast-pin"></i></div>
                            <div class="stat-card-value" id="total-broadcasts-sent">128</div>
                            <div class="stat-card-label">Mensagens Globais (Total)</div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="oc-card stat-card hover-lift">
                            <div class="stat-card-icon text-success"><i class="bi bi-phone-vibrate"></i></div>
                            <div class="stat-card-value">98.2%</div>
                            <div class="stat-card-label">Taxa de Entrega Push</div>
                        </div>
                    </div>
                </div>

                <!-- Filters & Control Bar -->
                <div class="oc-card mb-4" data-aos="fade-up">
                    <div class="row g-3 align-items-center">
                        <div class="col-lg-3 col-md-6">
                            <label class="oc-label">Tipo de Alerta</label>
                            <select id="filter-notify-type" class="oc-input border-0 bg-dark">
                                <option value="">Todos os Tipos</option>
                                <option value="SYSTEM">Sistema / Manutenção</option>
                                <option value="WALLET_UPDATE">Financeiro (Wallets)</option>
                                <option value="MATCH_INVITE">Duelos e Partidas</option>
                                <option value="ACHIEVEMENT">Conquistas</option>
                                <option value="GUILD_ALERT">Clãs e Guildas</option>
                            </select>
                        </div>
                        <div class="col-lg-3 col-md-6">
                            <label class="oc-label">Estado de Leitura</label>
                            <div class="d-flex align-items-center h-100 mt-2 mt-md-0">
                                <div class="form-check form-switch ms-2">
                                    <input class="form-check-input" type="checkbox" id="filter-unread-only">
                                    <label class="form-check-label text-muted small" for="filter-unread-only">Apenas não lidas</label>
                                </div>
                            </div>
                        </div>
                        <div class="col-lg-4 col-md-8">
                            <label class="oc-label">Rastreio de Entrega</label>
                            <div class="small text-muted d-flex align-items-center gap-2 mt-2">
                                <i class="bi bi-info-circle text-info"></i>
                                <span>Notificações em tempo real via Socket.IO e Firebase Cloud Messaging (FCM).</span>
                            </div>
                        </div>
                        <div class="col-lg-2 col-md-4">
                            <button class="btn-oc btn-oc-outline w-100" id="btn-refresh-notifications">
                                <i class="bi bi-arrow-clockwise"></i> Actualizar
                            </button>
                        </div>
                    </div>
                </div>

                <!-- Notifications Data Table -->
                <div class="oc-card p-0 overflow-hidden" data-aos="fade-up">
                    <div id="notify-loader" class="text-center py-5" style="display: none;">
                        <div class="spinner-custom mx-auto"></div>
                        <p class="text-muted mt-3 small">Sincronizando com o servidor de mensagens...</p>
                    </div>
                    <div class="oc-table-container">
                        <table class="oc-table mb-0" id="notifications-table">
                            <thead>
                                <tr>
                                    <th class="text-center" style="width: 60px;">#</th>
                                    <th>Conteúdo e Destinatário</th>
                                    <th>Categoria</th>
                                    <th>Data de Envio</th>
                                    <th class="text-end pe-4">Gestão</th>
                                </tr>
                            </thead>
                            <tbody>
                                <!-- Injetado dinamicamente via notifications.js -->
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- Pagination -->
                <div class="d-flex justify-content-between align-items-center mt-4" data-aos="fade-up">
                    <div class="text-dim small">
                        Padrão operacional: Ordem cronológica decrescente
                    </div>
                    <div class="pagination-wrapper" id="notify-pagination">
                        <!-- Gerado via JS -->
                    </div>
                </div>
            </main>

            <!-- Modal: Novo Broadcast / Enviar Notificação -->
            <div class="modal fade" id="notification-modal" tabindex="-1" aria-hidden="true">
                <div class="modal-dialog modal-dialog-centered">
                    <div class="modal-content shadow-lg border-secondary">
                        <div class="modal-header border-secondary bg-main">
                            <h5 class="modal-title fw-bold">Disparar Alerta em Tempo Real</h5>
                            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                        </div>
                        <form id="notification-send-form">
                            <div class="modal-body p-4">
                                <div class="oc-input-group">
                                    <label class="oc-label">Título da Mensagem</label>
                                    <input type="text" name="title" class="oc-input" required maxlength="100" placeholder="Ex: Manutenção Agendada">
                                </div>
                                <div class="oc-input-group">
                                    <label class="oc-label">Corpo da Notificação</label>
                                    <textarea name="message" class="oc-input" rows="3" required maxlength="500" placeholder="Digite a mensagem que o usuário receberá..."></textarea>
                                </div>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="oc-input-group">
                                            <label class="oc-label">Tipo</label>
                                            <select name="type" class="oc-input" required>
                                                <option value="SYSTEM">Sistema</option>
                                                <option value="WALLET_UPDATE">Finanças</option>
                                                <option value="MATCH_INVITE">Jogo</option>
                                                <option value="GUILD_ALERT">Guilda</option>
                                            </select>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="oc-input-group">
                                            <label class="oc-label">Destinatário (Opcional)</label>
                                            <input type="text" name="userId" class="oc-input" placeholder="UUID do usuário">
                                            <small class="text-dim" style="font-size: 9px;">Vazio para todos os usuários (Broadcast)</small>
                                        </div>
                                    </div>
                                </div>
                                <div class="oc-input-group mb-0">
                                    <label class="oc-label">Link de Redirecionamento (Opcional)</label>
                                    <input type="url" name="link" class="oc-input" placeholder="https://otakuclash.ao/...">
                                </div>
                            </div>
                            <div class="modal-footer border-secondary bg-main">
                                <button type="button" class="btn-oc btn-oc-outline" data-bs-dismiss="modal">Cancelar</button>
                                <button type="submit" class="btn-oc btn-oc-primary" id="btn-send-notification">
                                    <i class="bi bi-send me-2"></i> Disparar Mensagem
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

            <!-- Global Footer & Scripts -->
            <%- include('../../partials/footer', { moduleScript: 'notifications/notifications' }) %>
        </div>
    </div>
</body>
</html>